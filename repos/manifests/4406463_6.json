));\n            // maybe this alternative has no values at all - e.g. because it was\n            // just created\n            if ((v != null) // there is a Values object\n                && (v.getList().size() > record) // there can be a value for\n                                                 // this sample record\n                && (v.getList().get(record) != null)) { // there is a value\n                log.debug(\"removing values:: \" + getName() + \" ,\" + record + \", \" + a.getName());\n                v.getList().remove(record);\n            }\n        }\n    }", "signature": "void removeValues(List<Alternative> list, int record)", "full_signature": "public void removeValues(List<Alternative> list, int record)", "class_method_signature": "Leaf.removeValues(List<Alternative> list, int record)", "testcase": false, "constructor": false, "invocations": ["getValues", "getName", "size", "getList", "get", "getList", "debug", "getName", "getName", "remove", "getList"]}, "repository": {"repo_id": 4406463, "url": "https://github.com/openpreserve/plato", "language": "Java", "is_fork": false, "fork_count": 5, "stargazer_count": 8, "size": 66861, "license": "licensed"}}