InventoryWithLDraftLotItems()", "full_signature": "@Test public void shouldRestoreDraftInventoryWithLDraftLotItems()", "class_method_signature": "PhysicalInventoryPresenterTest.shouldRestoreDraftInventoryWithLDraftLotItems()", "testcase": true, "constructor": false, "invocations": ["getStockCardViewModels", "setStockCard", "setQuantity", "build", "setQuantity", "setExpiryDate", "setLotNumber", "build", "setQuantity", "setExpiryDate", "setLotNumber", "setExistingLotMovementViewModelList", "get", "newArrayList", "getProduct", "getProduct", "setDraftLotItemListWrapper", "newArrayList", "add", "thenReturn", "when", "queryAllDraft", "addAll", "getInventoryViewModelList", "restoreDraftInventory", "assertThat", "getLotNumber", "get", "getNewLotMovementViewModelList", "get", "is", "assertThat", "getLotNumber", "get", "getExistingLotMovementViewModelList", "get", "is"]}, "focal_class": {"identifier": "PhysicalInventoryPresenter", "superclass": "extends InventoryPresenter", "interfaces": "", "fields": [{"original_string": "@Inject\n    StockService stockService;", "modifier": "@Inject", "type": "StockService", "declarator": "stockService", "var_name": "stockService"}, {"original_string": "@Inject\n    StockMovementRepository movementRepository;", "modifier": "@Inject", "type": "StockMovementRepository", "declarator": "movementRepository", "var_name": "movementRepository"}], "methods": [{"identifier": "loadInventory", "parameters": "()", "modifiers": "@Override public", "return": "Observable<List<InventoryViewModel>>", "signature": "Observable<List<InventoryViewModel>> loadInventory()", "full_signature": "@Override public Observable<List<InventoryViewModel>> loadInventory()", "class_method_signature": "PhysicalInventoryPresenter.loadInventory()", "testcase": false, "constructor": false}, {"identifier": "convertStockCardsToStockCardViewModels", "parameters": "(List<StockCard> validStockCardsForPhysicalInventory)", "modifiers": "private", "return": "List<InventoryViewModel>", "s