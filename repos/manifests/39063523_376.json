/view/holder/StockMovementViewHolder.java"}, "focal_method": {"identifier": "getPreviousMovementDate", "parameters": "(StockCard stockCard)", "modifiers": "protected", "return": "Date", "body": "protected Date getPreviousMovementDate(StockCard stockCard) {\n        List<StockMovementItem> stockMovements = stockCard.getStockMovementItemsWrapper();\n        if (stockMovements != null) {\n            if (!stockMovements.isEmpty()) {\n                Collections.sort(stockMovements, (item1, item2) -> item1.getMovementDate().compareTo(item2.getMovementDate()));\n                return stockMovements.get(stockMovements.size() - 1).getMovementDate();\n            }\n        }\n        return null;\n    }", "signature": "Date getPreviousMovementDate(StockCard stockCard)", "full_signature": "protected Date getPreviousMovementDate(StockCard stockCard)", "class_method_signature": "StockMovementViewHolder.getPreviousMovementDate(StockCard stockCard)", "testcase": false, "constructor": false, "invocations": ["getStockMovementItemsWrapper", "isEmpty", "sort", "compareTo", "getMovementDate", "getMovementDate", "getMovementDate", "get", "size"]}, "repository": {"repo_id": 39063523, "url": "https://github.com/SIGLUS/lmis-moz-mobile", "stars": 15, "created": "7/14/2015 8:34:48 AM +00:00", "updates": "2020-01-07T14:05:00+00:00", "fork": "False", "license": "licensed"}}