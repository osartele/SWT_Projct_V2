entItems)", "class_method_signature": "MMIARepository.getMMiAInitialAmount(StockCard stockCard, List<StockMovementItem> stockMovementItems)", "testcase": false, "constructor": false}, {"identifier": "assignMMIATotalValues", "parameters": "(RnrFormItem rnrFormItem, List<StockMovementItem> stockMovementItems)", "modifiers": "private", "return": "void", "signature": "void assignMMIATotalValues(RnrFormItem rnrFormItem, List<StockMovementItem> stockMovementItems)", "full_signature": "private void assignMMIATotalValues(RnrFormItem rnrFormItem, List<StockMovementItem> stockMovementItems)", "class_method_signature": "MMIARepository.assignMMIATotalValues(RnrFormItem rnrFormItem, List<StockMovementItem> stockMovementItems)", "testcase": false, "constructor": false}, {"identifier": "initMMiARnrFormItemWithoutMovement", "parameters": "(RnrFormItem rnrFormItem, long lastRnrInventory)", "modifiers": "private", "return": "void", "signature": "void initMMiARnrFormItemWithoutMovement(RnrFormItem rnrFormItem, long lastRnrInventory)", "full_signature": "private void initMMiARnrFormItemWithoutMovement(RnrFormItem rnrFormItem, long lastRnrInventory)", "class_method_signature": "MMIARepository.initMMiARnrFormItemWithoutMovement(RnrFormItem rnrFormItem, long lastRnrInventory)", "testcase": false, "constructor": false}, {"identifier": "fillAllMMIAProducts", "parameters": "(RnRForm form, List<RnrFormItem> rnrFormItems)", "modifiers": "protected", "return": "ArrayList<RnrFormItem>", "signature": "ArrayList<RnrFormItem> fillAllMMIAProducts(RnRForm form, List<RnrFormItem> rnrFormItems)", "full_signature": "protected ArrayList<RnrFormItem> fillAllMMIAProducts(RnRForm form, List<RnrFormItem> rnrFormItems)", "class_method_signature": "MMIARepository.fillAllMMIAProducts(RnRForm form, List<RnrFormItem> rnrFormItems)", "testcase": false, "constructor": false}, {"identifier": "getStockCardRnr", "parameters": "(Product product, List<RnrFormItem> rnrStockFormItems)", "modifiers": "private", "return": "RnrFormItem", "signature": "RnrFormItem getStockCardRnr(Product product, List<RnrFormItem> rnrStockFormItems)", "full_signature": "private RnrFormItem getStockCardRnr(Product product, List<RnrFormItem> rnrStockFormItems)", "class_method_signature": "MMIARepository.getStockCardRnr(Product product, List<RnrFormItem> rnrStockFormItems)", "testcase": false, "constructor": false}], "file": "app/src/main/java/org/openlmis/core/model/repository/MMIARepository.java"}, "focal_method": {"identifier": "generateBaseInfoItems", "parameters": "(final RnRForm form, ReportType type)", "modifiers": "@Override protected", "return": "List<BaseInfoItem>", "body": "@Override\n    protected List<BaseInfoItem> generateBaseInfoItems(final RnRForm form, ReportType type) {\n\n        if (ReportType.NEW != type) {\n            ArrayList<String> attrs = new ArrayList<>();\n            attrs.add(ATTR_NEW_PATIENTS);\n            attrs.add(ATTR_SUSTAINING);\n            attrs.add(ATTR_ALTERATION);\n            attrs.add(ATTR_PTV);\n            attrs.add(ATTR_PPE);\n            attrs.add(ATTR_TOTAL_MONTH_DISPENSE);\n            attrs.add(ATTR_TOTAL_PATIENTS);\n\n            return FluentIterable.from(attrs)\n                    .transform(attr -> new BaseInfoItem(attr, BaseInfoItem.TYPE.INT, form, \"\", 0))\n                    .toList();\n        }\n\n        Map<String, String> mAttrs = new HashMap<>();\n        initAttrs(mAttrs);\n\n        initDisplayOrder();\n\n        return FluentIterable.from(mAttrs.keySet())\n                .transform(key -> new BaseInfoItem(key, BaseInfoItem.TYPE.INT, form, mAttrs.get(key), getDisplayOrder(key)))\n                .toSortedList((o1, o2) -> o1.getDisplayOrder() - o2.getDisplayOrder());\n    }", "signature": "List<BaseInfoItem> generateBaseInfoItems(final RnRForm form, ReportType type)", "full_signature": "@Override protected List<BaseInfoItem> generateBaseInfoItems(final RnRForm form, ReportType type)", "class_method_signature": "MMIARepository.generateBaseInfoItems(final RnRForm form, ReportType type)", "testcase": false, "constructor": false, "invocations": ["add", "add", "add", "add", "add", "add", "add", "toList", "transform", "from", "initAttrs", "initDisplayOrder", "toSortedList", "transform", "from", "keySet", "get", "getDisplayOrder", "getDisplayOrder", "getDisplayOrder"]}, "repository": {"repo_id": 39063523, "url": "https://github.com/SIGLUS/lmis-moz-mobile", "stars": 15, "created": "7/14/2015 8:34:48 AM +00:00", "updates": "2020-01-07T14:05:00+00:00", "fork": "False", "license": "licensed"}}