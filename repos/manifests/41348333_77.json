ootDir, userShortName, true);\n  }", "signature": "Path getApexDFSRootDir(FileSystem fs, Configuration conf)", "full_signature": "public static Path getApexDFSRootDir(FileSystem fs, Configuration conf)", "class_method_signature": "StramClientUtils.getApexDFSRootDir(FileSystem fs, Configuration conf)", "testcase": false, "constructor": false, "invocations": ["get", "getBoolean", "getShortUserName", "getCurrentUser", "warn", "getDTDFSRootDir", "isBlank", "getDefaultRootFolder", "evalDFSRootDir"]}, "repository": {"repo_id": 41348333, "url": "https://github.com/apache/attic-apex-core", "language": "Java", "is_fork": false, "fork_count": 181, "stargazer_count": 346, "size": 14734, "license": "licensed"}}