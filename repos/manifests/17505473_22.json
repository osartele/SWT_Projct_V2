nfig config = defaultConfig.copy();\n        config.setCollectionType(List.class);\n        config.setRootClass(Item.class);\n        config.setJavaPropertyFilter(new PropertyFilter() {\n            @Override\n            public boolean apply(Object source, String name, Object value) {\n                if (\"hosts\".equals(name)) {\n                    return true;\n                }\n                return false;\n            }\n        });\n\n        return (List<Item>) JSONArray.toCollection(result, config);\n    }", "signature": "List<Item> get(ItemGetParam param)", "full_signature": "@SuppressWarnings(\"unchecked\") public List<Item> get(ItemGetParam param)", "class_method_signature": "ItemClient.get(ItemGetParam param)", "testcase": false, "constructor": false, "invocations": ["fromObject", "execute", "copy", "setCollectionType", "setRootClass", "setJavaPropertyFilter", "equals", "toCollection"]}, "repository": {"repo_id": 17505473, "url": "https://github.com/primecloud-controller-org/primecloud-controller", "language": "Java", "is_fork": false, "fork_count": 14, "stargazer_count": 19, "size": 18077, "license": "licensed"}}