pe type)", "modifiers": "public static", "return": "Charset", "signature": "Charset getCharsetDefault(final ContentType type)", "full_signature": "public static Charset getCharsetDefault(final ContentType type)", "class_method_signature": "HttpUtil.getCharsetDefault(final ContentType type)", "testcase": false, "constructor": false}, {"identifier": "isEntityEnclosingMethod", "parameters": "(final String method)", "modifiers": "public static", "return": "boolean", "signature": "boolean isEntityEnclosingMethod(final String method)", "full_signature": "public static boolean isEntityEnclosingMethod(final String method)", "class_method_signature": "HttpUtil.isEntityEnclosingMethod(final String method)", "testcase": false, "constructor": false}, {"identifier": "isEntityEnclosingMethod", "parameters": "(final HTTPMethod method)", "modifiers": "public static", "return": "boolean", "signature": "boolean isEntityEnclosingMethod(final HTTPMethod method)", "full_signature": "public static boolean isEntityEnclosingMethod(final HTTPMethod method)", "class_method_signature": "HttpUtil.isEntityEnclosingMethod(final HTTPMethod method)", "testcase": false, "constructor": false}, {"identifier": "getXWwwFormUrlEncoded2Map", "parameters": "(String str)", "modifiers": "public static", "return": "MultiValueMap<String, String>", "signature": "MultiValueMap<String, String> getXWwwFormUrlEncoded2Map(String str)", "full_signature": "public static MultiValueMap<String, String> getXWwwFormUrlEncoded2Map(String str)", "class_method_signature": "HttpUtil.getXWwwFormUrlEncoded2Map(String str)", "testcase": false, "constructor": false}], "file": "restclient-lib/src/main/java/org/wiztools/restclient/util/HttpUtil.java"}, "focal_method": {"identifier": "getContentType", "parameters": "(String header)", "modifiers": "public static", "return": "ContentType", "body": "public static ContentType getContentType(String header) {\n        final String[] arr = header.split(\"\\\\s*;\\\\s*\");\n        if(arr.length == 1) {\n            return new ContentTypeBean(header, null);\n        }\n        else {\n            final String contentType = arr[0];\n            for(int i=1; i<arr.length; i++) {\n                final String headerPart = arr[i];\n                if(headerPart.contains(\"charset=\")) {\n                    Pattern p = Pattern.compile(\"charset=(.+)\");\n                    Matcher m = p.matcher(headerPart);\n                    if(m.matches()) {\n                        Charset charset = Charset.forName(m.group(1));\n                        return new ContentTypeBean(contentType, charset);\n                    }\n                }\n            }\n            return new ContentTypeBean(contentType, null);\n        }\n    }", "signature": "ContentType getContentType(String header)", "full_signature": "public static ContentType getContentType(String header)", "class_method_signature": "HttpUtil.getContentType(String header)", "testcase": false, "constructor": false, "invocations": ["split", "contains", "compile", "matcher", "matches", "forName", "group"]}, "repository": {"repo_id": 16481293, "url": "https://github.com/wiztools/rest-client", "language": "Java", "is_fork": false, "fork_count": 371, "stargazer_count": 1458, "size": 3393, "license": "licensed"}}