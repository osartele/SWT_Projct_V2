validateDisable(Lang lang)", "class_method_signature": "LanguageService.validateDisable(Lang lang)", "testcase": false, "constructor": false}], "file": "engine/src/main/java/org/entando/entando/aps/system/services/language/LanguageService.java"}, "focal_method": {"identifier": "getLanguages", "parameters": "(RestListRequest requestList)", "modifiers": "@Override public", "return": "PagedMetadata<LanguageDto>", "body": "@Override\n    public PagedMetadata<LanguageDto> getLanguages(RestListRequest requestList) {\n        try {\n            List<Lang> sysLangs = this.getLangManager().getAssignableLangs();\n            List<LanguageDto> langs = this.getLanguageDtoBuilder().convert(sysLangs);\n            \n            langs = new LanguageRequestListProcessor(requestList, langs)\n                    .filterAndSort().toList();\n\n            //page\n            SearcherDaoPaginatedResult<LanguageDto> langsResult = new SearcherDaoPaginatedResult<>(langs.size(), langs);\n            langsResult.setCount(langs.size());\n            PagedMetadata<LanguageDto> pagedMetadata = new PagedMetadata<>(requestList, langsResult);\n            pagedMetadata.setBody(langs);\n            pagedMetadata.imposeLimits();\n            return pagedMetadata;\n        } catch (Throwable t) {\n            logger.error(\"error in search langs\", t);\n            throw new RestServerError(\"error in search langs\", t);\n        }\n    }", "signature": "PagedMetadata<LanguageDto> getLanguages(RestListRequest requestList)", "full_signature": "@Override public PagedMetadata<LanguageDto> getLanguages(RestListRequest requestList)", "class_method_signature": "LanguageService.getLanguages(RestListRequest requestList)", "testcase": false, "constructor": false, "invocations": ["getAssignableLangs", "getLangManager", "convert", "getLanguageDtoBuilder", "toList", "filterAndSort", "size", "setCount", "size", "setBody", "imposeLimits", "error"]}, "repository": {"repo_id": 23227907, "url": "https://github.com/entando/entando-core", "stars": 56, "created": "8/22/2014 2:23:11 PM +00:00", "updates": "2020-01-22T21:34:59+00:00", "fork": "False", "license": "licensed"}}