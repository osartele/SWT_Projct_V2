{"test_class": {"identifier": "AddDrugsToVIAPresenterTest", "superclass": "", "interfaces": "", "fields": [{"original_string": "private AddDrugsToVIAPresenter presenter;", "modifier": "private", "type": "AddDrugsToVIAPresenter", "declarator": "presenter", "var_name": "presenter"}, {"original_string": "private ProductRepository productRepository;", "modifier": "private", "type": "ProductRepository", "declarator": "productRepository", "var_name": "productRepository"}, {"original_string": "private ProgramRepository programRepository;", "modifier": "private", "type": "ProgramRepository", "declarator": "programRepository", "var_name": "programRepository"}, {"original_string": "private ProductProgramRepository productProgramRepository;", "modifier": "private", "type": "ProductProgramRepository", "declarator": "productProgramRepository", "var_name": "productProgramRepository"}, {"original_string": "private RnrFormItemRepository rnrFormItemRepository;", "modifier": "private", "type": "RnrFormItemRepository", "declarator": "rnrFormItemRepository", "var_name": "rnrFormItemRepository"}, {"original_string": "private StockRepository stockRepository;", "modifier": "private", "type": "StockRepository", "declarator": "stockRepository", "var_name": "stockRepository"}, {"original_string": "private RnrFormHelper rnrFormHelper;", "modifier": "private", "type": "RnrFormHelper", "declarator": "rnrFormHelper", "var_name": "rnrFormHelper"}], "file": "app/src/test/java/org/openlmis/core/presenter/AddDrugsToVIAPresenterTest.java"}, "test_case": {"identifier": "loadActiveProductsNotInVIAForm", "parameters": "()", "modifiers": "@Test public", "return": "void", "body": "@Test\n    public void loadActiveProductsNotInVIAForm() throws Exception {\n        Product product1 = new ProductBuilder().setCode(\"P1\").setPrimaryName(\"A1\").build();\n        Product product2 = new ProductBuilder().setCode(\"P2\").setPrimaryName(\"A2\").build();\n        Product product3 = new ProductBuilder().setCode(\"P3\").setPrimaryName(\"A3\").build();\n        Product product4 = new ProductBuilder().setCode(\"P4\").setPrimaryName(\"A4\").build();\n\n\n        when(productRepository.queryActiveProductsInVIAProgramButNotInDraftVIAForm()).thenReturn(newArrayList(product1, product2, product3, product4));\n\n        TestSubscriber<Void> subscriber = new TestSubscriber<>();\n        presenter.loadActiveProductsNotInVIAForm(newArrayList(\"P3\", \"P4\")).subscribe(subscriber);\n\n        subscriber.awaitTerminalEvent();\n\n        subscriber.assertNoErrors();\n\n        assertThat(presenter.getInventoryViewModelList().size(), is(2));\n        assertThat(presenter.getInventoryViewModelList().get(0).getProductName(), is(\"A1\"));\n        assertThat(presenter.getInventoryViewModelList().get(1).getProductName(), is(\"A2\"));\n    }", "signature": "void loadActiveProductsNotInVIAForm()", "full_signature": "@Test public void loadActiveProductsNotInVIAForm()", "class_method_signature": "AddDrugsToVIAPresenterTest.loadActiveProductsNotInVIAForm()", "testcase": true, "constructor": false, "invocations": ["build", "setPrimaryName", "setCode", "build", "setPrimaryName", "setCode", "build", "setPrimaryName", "setCode", "build", "setPrimaryName", "setCode", "thenReturn", "when", "queryActiveProductsInVIAProgramButNotInDraftVIAForm", "newArrayList", "subscribe", "loadActiveProductsNotInVIAForm", "newArrayList", "awaitTerminalEvent", "assertNoErrors", "assertThat", "size", "getInventoryViewModelList", "is", "assertThat", "getProductName", "get", "getInventoryViewModelList", "is", "assertThat", "getProductName", "get", "getInventoryViewModelList", "is"]}, "focal_class": {"identifier": "AddDrugsToVIAPresenter", "superclass": "extends Presenter", "interfaces": "", "fields": [{"original_string": "@Inject\n    private ProductRepository productRepository;", "modifier": "@Inject\n    private", "type": "ProductRepository", "declarator": "productRepository", "var_name": "productRepository"}, {"original_string": "@Getter\n    final List<InventoryViewModel> inventoryViewModelList = new ArrayList<>();", "modifier": "@Getter\n    final", "type": "List<InventoryViewModel>", "declarator": "inventoryViewModelList = new ArrayList<>()", "var_name": "inventoryViewModelList"}], "methods": [{"identifier": "AddDrugsToVIAPresenter", "parameters": "()", "modifiers": "public", "return": "", "signature": " AddDrugsToVIAPresenter()", "full_signature": "public  AddDrugsToVIAPresenter()", "class_method_signature": "AddDrugsToVIAPresenter.AddDrugsToVIAPresenter()", "testcase": false, "constructor": true}, {"identifier": "attachView", "parameters": "(BaseView v)", "modifiers": "@Override public", "return": "void", "signature": "void attachView(BaseView v)", "full_signature": "@Override public void attachView(BaseView v)", "class_method_signature": "AddDrugsToVIAPresenter.attachView(BaseView v)", "testcase": false, "constructor": false}, {"identifier": "loadActiveProductsNotInVIAForm", "parameters": "(final List<String> existingProducts)", "modifiers": "public", "return": "Observable<Void>", "signature": "Observable<Void> loadActiveProductsNotInVIAForm(final List<String> existingProducts)", "full_signature": "public Observable<Void> loadActiveProductsNotInVIAForm(final List<String> existingProducts)", "class_method_signature": "AddDrugsToVIAPresenter.loadActiveProductsNotInVIAForm(final List<String> existingProducts)", "testcase": false, "constructor": false}, {"identifier": "convertViewModelsToRnrFormItems", "parameters": "()", "modifiers": "public", "return": "Observable<ArrayList<RnrFormItem>>", "signature": "Observable<ArrayList<RnrFormItem>> convertViewModelsToRnrFormItems()", "full_signature": "public Observable<ArrayList<RnrFormItem>> convertViewModelsToRnrFormItems()", "class_method_signature": "AddDrugsToVIAPresenter.convertViewModelsToRnrFormItems()", "testcase": false, "constructor": false}], "file": "app/src/main/java/org/openlmis/core/presenter/AddDrugsToVIAPresenter.java"}, "focal_method": {"identifier": "loadActiveProductsNotInVIAForm", "parameters": "(final List<String> existingProducts)", "modifiers": "public", "return": "Observable<Void>", "body": "public Observable<Void> loadActiveProductsNotInVIAForm(final List<String> existingProducts) {\n        return Observable.create((Observable.OnSubscribe<Void>) subscriber -> {\n            try {\n                inventoryViewModelList.addAll(FluentIterable\n                        .from(productRepository.queryActiveProductsInVIAProgramButNotInDraftVIAForm())\n                        .filter(product -> !existingProducts.contains(product.getCode()))\n                        .transform((Function<Product, InventoryViewModel>) product -> new AddDrugsToViaInventoryViewModel(product))\n                        .toList());\n                subscriber.onNext(null);\n                subscriber.onCompleted();\n            } catch (LMISException e) {\n                new LMISException(e, \"AddDrugsToVIAPresenter,loadActiveProductsNotInVIAForm\").reportToFabric();\n                subscriber.onError(e);\n            }\n        }).observeOn(AndroidSchedulers.mainThread()).subscribeOn(Schedulers.io());\n    }", "signature": "Observable<Void> loadActiveProductsNotInVIAForm(final List<String> existingProducts)", "full_signature": "public Observable<Void> loadActiveProductsNotInVIAForm(final List<String> existingProducts)", "class_method_signature": "AddDrugsToVIAPresenter.loadActiveProductsNotInVIAForm(final List<String> existingProducts)", "testcase": false, "constructor": false, "invocations": ["subscribeOn", "observeOn", "create", "addAll", "toList", "transform", "filter", "from", "queryActiveProductsInVIAProgramButNotInDraftVIAForm", "contains", "getCode", "onNext", "onCompleted", "reportToFabric", "onError", "mainThread", "io"]}, "repository": {"repo_id": 39063523, "url": "https://github.com/SIGLUS/lmis-moz-mobile", "stars": 15, "created": "7/14/2015 8:34:48 AM +00:00", "updates": "2020-01-07T14:05:00+00:00", "fork": "False", "license": "licensed"}}