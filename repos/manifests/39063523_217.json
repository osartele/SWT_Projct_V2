xception {\n        ConnectionSource connectionSource = DbUtil.getConnectionSource(LmisSqliteOpenHelper.getInstance(context));\n        return TransactionManager.callInTransaction(connectionSource, () -> {\n            genericDao.create(ptvProgram);\n            patientDispensationRepository.save(new ArrayList<>(ptvProgram.getPatientDispensations()));\n            ptvProgramStockInformationRepository.save(new ArrayList<>(ptvProgram.getPtvProgramStocksInformation()));\n            for (PTVProgramStockInformation ptvProgramStockInformation : ptvProgram.getPtvProgramStocksInformation()) {\n                serviceDispensationRepository.save(new ArrayList<>(ptvProgramStockInformation.getServiceDispensations()));\n            }\n            return ptvProgram;\n        });\n    }", "signature": "PTVProgram save(final PTVProgram ptvProgram)", "full_signature": "public PTVProgram save(final PTVProgram ptvProgram)", "class_method_signature": "PTVProgramRepository.save(final PTVProgram ptvProgram)", "testcase": false, "constructor": false, "invocations": ["getConnectionSource", "getInstance", "callInTransaction", "create", "save", "getPatientDispensations", "save", "getPtvProgramStocksInformation", "getPtvProgramStocksInformation", "save", "getServiceDispensations"]}, "repository": {"repo_id": 39063523, "url": "https://github.com/SIGLUS/lmis-moz-mobile", "stars": 15, "created": "7/14/2015 8:34:48 AM +00:00", "updates": "2020-01-07T14:05:00+00:00", "fork": "False", "license": "licensed"}}