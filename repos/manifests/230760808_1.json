day) {\n\t\t\t\tp.setYdPosition(p.getYdPosition() - nPosition);\n\t\t\t\tp.setPosition(p.getPosition() - nPosition);\n\t\t\t}else {\n\t\t\t\tp.setPosition(p.getPosition() - nPosition);\n\t\t\t\tp.setTdPosition(p.getTdPosition() - Math.min(p.getTdPosition(), nPosition));\n\t\t\t\tp.setYdPosition(p.getPosition() - p.getTdPosition());\n\t\t\t}\n\t\t\tp.setExchangeMargin(p.getOpenPrice() * p.getPosition() * contract.getMultiplier() * marginRatio);\n\t\t\tp.setUseMargin(p.getExchangeMargin());\n\t\t}\n\t\t\n\t\treturn p.convertTo();\n\t}", "signature": "PositionField reducePosition(TradeField tradeField)", "full_signature": "public PositionField reducePosition(TradeField tradeField)", "class_method_signature": "GwPosition.reducePosition(TradeField tradeField)", "testcase": false, "constructor": false, "invocations": ["getUnifiedSymbol", "getContract", "getUnifiedSymbol", "getContract", "equals", "getVolume", "getOffsetFlag", "setTdPosition", "getTdPosition", "setPosition", "getPosition", "getOffsetFlag", "setYdPosition", "getYdPosition", "setPosition", "getPosition", "setPosition", "getPosition", "setTdPosition", "getTdPosition", "min", "getTdPosition", "setYdPosition", "getPosition", "getTdPosition", "setExchangeMargin", "getOpenPrice", "getPosition", "getMultiplier", "setUseMargin", "getExchangeMargin", "convertTo"]}, "repository": {"repo_id": 230760808, "url": "https://github.com/kevinhuangwl/northstar", "language": "Java", "is_fork": false, "fork_count": 1, "stargazer_count": 5, "size": 18899, "license": "licensed"}}