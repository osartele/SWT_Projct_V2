001\")).thenReturn(reserve);\n        when(tourInfoSharedService.findOneWithDetails(\"01\")).thenReturn(tour);\n        when(tourInfoSharedService.isOverPaymentLimit(tour)).thenReturn(false); // within limit\n\n        reserveService.cancel(\"001\");\n\n        ArgumentCaptor<String> argOfDelete = ArgumentCaptor.forClass(\n                String.class);\n        verify(reserveRepository, times(1)).deleteById(argOfDelete.capture());\n\n        assertThat(argOfDelete.getValue(), is(\"001\"));\n    }", "signature": "void testCancel01()", "full_signature": "@Test public void testCancel01()", "class_method_signature": "ReserveServiceImplTest.testCancel01()", "testcase": true, "constructor": false, "invocations": ["setAdultCount", "setChildCount", "setTourInfo", "setTransfer", "thenReturn", "when", "findById", "of", "thenReturn", "when", "findOneForUpdate", "thenReturn", "when", "findOneWithDetails", "thenReturn", "when", "isOverPaymentLimit", "cancel", "forClass", "deleteById", "verify", "times", "capture", "assertThat", "getValue", "is"]}, "focal_class": {"identifier": "ReserveServiceImpl", "superclass": "", "interfaces": "implements ReserveService", "fields": [{"original_string": "@Inject\n    ReserveRepository reserveRepository;", "modifier": "@Inject", "type": "ReserveRepository", "declarator": "reserveRepository", "var_name": "reserveRepository"}, {"original_string": "@Inject\n    AuthorizedReserveSharedService authorizedReserveSharedService;", "modifier": "@Inject", "type": "AuthorizedReserveSharedService", "declarator": "authorizedReserveSharedService", "var_name": "authorizedReserveSharedService"}, {"original_string": "@Inject\n    TourInfoSharedService tourInfoSharedService;", "modifier": "@Inject", "type": "TourInfoSharedService", "declarator": "tourInfoSharedService", "var_name": "tourInfoSharedService"}, {"original_string": "@Inject\n    PriceCalculateSharedService priceCalculateService;", "modifier": "@Inject", "type": "PriceCalculateSharedService", "declara