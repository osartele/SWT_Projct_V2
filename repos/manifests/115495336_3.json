{"test_class": {"identifier": "DefaultProteusSocketTest", "superclass": "", "interfaces": "", "fields": [], "file": "proteus-client/src/test/java/io/netifi/proteus/rsocket/DefaultProteusSocketTest.java"}, "test_case": {"identifier": "testRequestChannel", "parameters": "()", "modifiers": "@Test public", "return": "void", "body": "@Test\n  public void testRequestChannel() {\n    Payload incoming = Mockito.mock(Payload.class);\n\n    Payload transformed = ByteBufPayload.create(\"transformed\");\n    Payload outgoing = ByteBufPayload.create(\"outgoing\");\n\n    DefaultProteusSocket socket =\n        new DefaultProteusSocket(\n            payload -> transformed,\n            () ->\n                new AbstractRSocket() {\n                  @Override\n                  public Flux<Payload> requestChannel(Publisher<Payload> payloads) {\n                    return Flux.from(payloads).thenMany(Flux.just(outgoing));\n                  }\n                });\n    Payload block = socket.requestChannel(Mono.just(incoming)).blockLast();\n\n    Assert.assertTrue(block == outgoing);\n    Mockito.verify(incoming, Mockito.times(0)).release();\n  }", "signature": "void testRequestChannel()", "full_signature": "@Test public void testRequestChannel()", "class_method_signature": "DefaultProteusSocketTest.testRequestChannel()", "testcase": true, "constructor": false, "invocations": ["mock", "create", "create", "thenMany", "from", "just", "blockLast", "requestChannel", "just", "assertTrue", "release", "verify", "times"]}, "focal_class": {"identifier": "DefaultProteusSocket", "superclass": "", "interfaces": "implements ProteusSocket", "fields": [{"original_string": "private static final Logger logger = LoggerFactory.getLogger(DefaultProteusSocket.class);", "modifier": "private static final", "type": "Logger", "declarator": "logger = LoggerFactory.getLogger(DefaultProteusSocket.class)", "var_name": "logger"}, {"original_string": "private final Function<Payload, Payload> payloadTransformer;"