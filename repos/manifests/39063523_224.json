ic Date getLastStockMovementCreatedTime()", "class_method_signature": "StockCard.getLastStockMovementCreatedTime()", "testcase": false, "constructor": false}, {"identifier": "getNonEmptyLotOnHandList", "parameters": "()", "modifiers": "public", "return": "List<LotOnHand>", "signature": "List<LotOnHand> getNonEmptyLotOnHandList()", "full_signature": "public List<LotOnHand> getNonEmptyLotOnHandList()", "class_method_signature": "StockCard.getNonEmptyLotOnHandList()", "testcase": false, "constructor": false}, {"identifier": "getNoneExpiredLotOnHandList", "parameters": "()", "modifiers": "public", "return": "List<LotOnHand>", "signature": "List<LotOnHand> getNoneExpiredLotOnHandList()", "full_signature": "public List<LotOnHand> getNoneExpiredLotOnHandList()", "class_method_signature": "StockCard.getNoneExpiredLotOnHandList()", "testcase": false, "constructor": false}, {"identifier": "toString", "parameters": "()", "modifiers": "@Override public", "return": "String", "signature": "String toString()", "full_signature": "@Override public String toString()", "class_method_signature": "StockCard.toString()", "testcase": false, "constructor": false}], "file": "app/src/main/java/org/openlmis/core/model/StockCard.java"}, "focal_method": {"identifier": "getEarliestLotExpiryDate", "parameters": "()", "modifiers": "public", "return": "Date", "body": "public Date getEarliestLotExpiryDate() {\n        List<LotOnHand> lotOnHandList = FluentIterable.from(getNonEmptyLotOnHandList()).filter(lotOnHand -> lotOnHand.getQuantityOnHand() > 0).toList();\n        if (lotOnHandList.isEmpty()) {\n            return null;\n        }\n        return Collections.min(lotOnHandList, (lhs, rhs) -> lhs.getLot().getExpirationDate().compareTo(rhs.getLot().getExpirationDate())).getLot().getExpirationDate();\n    }", "signature": "Date getEarliestLotExpiryDate()", "full_signature": "public Date getEarliestLotExpiryDate()", "class_method_signature": "StockCard.getEarliestLotExpiryDate()", "testcase": false,