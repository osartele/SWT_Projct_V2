Override\n            public void call(Subscriber<? super RnRForm> subscriber) {\n                try {\n                    rnRForm = getRnrForm(formId);\n                    subscriber.onNext(rnRForm);\n                    subscriber.onCompleted();\n                } catch (LMISException e) {\n                    new LMISException(e, \"ALRequisitionPresenter,getRnrFormObservable\").reportToFabric();\n                    subscriber.onError(e);\n                }\n            }\n        }).observeOn(AndroidSchedulers.mainThread()).subscribeOn(Schedulers.io());\n    }", "signature": "Observable<RnRForm> getRnrFormObservable(long formId)", "full_signature": "@Override protected Observable<RnRForm> getRnrFormObservable(long formId)", "class_method_signature": "ALRequisitionPresenter.getRnrFormObservable(long formId)", "testcase": false, "constructor": false, "invocations": ["subscribeOn", "observeOn", "create", "getRnrForm", "onNext", "onCompleted", "reportToFabric", "onError", "mainThread", "io"]}, "repository": {"repo_id": 39063523, "url": "https://github.com/SIGLUS/lmis-moz-mobile", "stars": 15, "created": "7/14/2015 8:34:48 AM +00:00", "updates": "2020-01-07T14:05:00+00:00", "fork": "False", "license": "licensed"}}