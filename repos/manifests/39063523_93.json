java/org/openlmis/core/presenter/PhysicalInventoryPresenterTest.java"}, "test_case": {"identifier": "shouldCalculateStockAdjustment", "parameters": "()", "modifiers": "@Test public", "return": "void", "body": "@Test\n    public void shouldCalculateStockAdjustment() throws LMISException {\n        InventoryViewModel model = new InventoryViewModel(stockCardWithIdNine);\n        model.getNewLotMovementViewModelList().add(new LotMovementViewModelBuilder().setExpiryDate(\"Jan 2015\").setQuantity(\"100\").build());\n\n        StockMovementItem item = presenter.calculateAdjustment(model, stockCardWithIdNine);\n\n        assertThat(item.getMovementType(), is(MovementReasonManager.MovementType.PHYSICAL_INVENTORY));\n        assertThat(item.getMovementQuantity(), is(0L));\n        assertThat(item.getStockOnHand(), is(100L));\n        assertThat(item.getStockCard(), is(stockCardWithIdNine));\n    }", "signature": "void shouldCalculateStockAdjustment()", "full_signature": "@Test public void shouldCalculateStockAdjustment()", "class_method_signature": "PhysicalInventoryPresenterTest.shouldCalculateStockAdjustment()", "testcase": true, "constructor": false, "invocations": ["add", "getNewLotMovementViewModelList", "build", "setQuantity", "setExpiryDate", "calculateAdjustment", "assertThat", "getMovementType", "is", "assertThat", "getMovementQuantity", "is", "assertThat", "getStockOnHand", "is", "assertThat", "getStockCard", "is"]}, "focal_class": {"identifier": "PhysicalInventoryPresenter", "superclass": "extends InventoryPresenter", "interfaces": "", "fields": [{"original_string": "@Inject\n    StockService stockService;", "modifier": "@Inject", "type": "StockService", "declarator": "stockService", "var_name": "stockService"}, {"original_string": "@Inject\n    StockMovementRepository movementRepository;", "modifier": "@Inject", "type": "StockMovementRepository", "declarator": "movementRepository", "var_name": "movementRepository"}], "methods": [{"identifier": "loadInventory", "pa