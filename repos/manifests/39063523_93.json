oh(InventoryViewModel viewModel)", "full_signature": "private void populateLotMovementModelWithExistingSoh(InventoryViewModel viewModel)", "class_method_signature": "PhysicalInventoryPresenter.populateLotMovementModelWithExistingSoh(InventoryViewModel viewModel)", "testcase": false, "constructor": false}, {"identifier": "calculateAdjustment", "parameters": "(InventoryViewModel model, StockCard stockCard)", "modifiers": "protected", "return": "StockMovementItem", "signature": "StockMovementItem calculateAdjustment(InventoryViewModel model, StockCard stockCard)", "full_signature": "protected StockMovementItem calculateAdjustment(InventoryViewModel model, StockCard stockCard)", "class_method_signature": "PhysicalInventoryPresenter.calculateAdjustment(InventoryViewModel model, StockCard stockCard)", "testcase": false, "constructor": false}, {"identifier": "saveDraftInventoryObservable", "parameters": "()", "modifiers": "public", "return": "Observable<Object>", "signature": "Observable<Object> saveDraftInventoryObservable()", "full_signature": "public Observable<Object> saveDraftInventoryObservable()", "class_method_signature": "PhysicalInventoryPresenter.saveDraftInventoryObservable()", "testcase": false, "constructor": false}, {"identifier": "doInventory", "parameters": "(final String sign)", "modifiers": "public", "return": "Observable<Object>", "signature": "Observable<Object> doInventory(final String sign)", "full_signature": "public Observable<Object> doInventory(final String sign)", "class_method_signature": "PhysicalInventoryPresenter.doInventory(final String sign)", "testcase": false, "constructor": false}, {"identifier": "hasInversionDateBetweenMovementAndDB", "parameters": "(List<StockMovementItem> newestEachMovementItems, Date now)", "modifiers": "private", "return": "boolean", "signature": "boolean hasInversionDateBetweenMovementAndDB(List<StockMovementItem> newestEachMovementItems, Date now)", "full_signature": "private boolean hasInversionDateBetweenMovementAndDB(List<StockMovementItem> newestEachMovementItems, Date now)", "class_method_signature": "PhysicalInventoryPresenter.hasInversionDateBetweenMovementAndDB(List<StockMovementItem> newestEachMovementItems, Date now)", "testcase": false, "constructor": false}, {"identifier": "saveInventoryDate", "parameters": "()", "modifiers": "private", "return": "void", "signature": "void saveInventoryDate()", "full_signature": "private void saveInventoryDate()", "class_method_signature": "PhysicalInventoryPresenter.saveInventoryDate()", "testcase": false, "constructor": false}, {"identifier": "setExistingLotViewModels", "parameters": "(InventoryViewModel inventoryViewModel)", "modifiers": "private", "return": "void", "signature": "void setExistingLotViewModels(InventoryViewModel inventoryViewModel)", "full_signature": "private void setExistingLotViewModels(InventoryViewModel inventoryViewModel)", "class_method_signature": "PhysicalInventoryPresenter.setExistingLotViewModels(InventoryViewModel inventoryViewModel)", "testcase": false, "constructor": false}, {"identifier": "updateAvgMonthlyConsumption", "parameters": "()", "modifiers": "public", "return": "void", "signature": "void updateAvgMonthlyConsumption()", "full_signature": "public void updateAvgMonthlyConsumption()", "class_method_signature": "PhysicalInventoryPresenter.updateAvgMonthlyConsumption()", "testcase": false, "constructor": false}, {"identifier": "getCompleteCount", "parameters": "()", "modifiers": "public", "return": "int", "signature": "int getCompleteCount()", "full_signature": "public int getCompleteCount()", "class_method_signature": "PhysicalInventoryPresenter.getCompleteCount()", "testcase": false, "constructor": false}], "file": "app/src/main/java/org/openlmis/core/presenter/PhysicalInventoryPresenter.java"}, "focal_method": {"identifier": "calculateAdjustment", "parameters": "(InventoryViewModel model, StockCard stockCard)", "modifiers": "protected", "return": "StockMovementItem", "body": "protected StockMovementItem calculateAdjustment(InventoryViewModel model, StockCard stockCard) {\n        Long inventory = model.getLotListQuantityTotalAmount();\n        long stockOnHand = model.getStockOnHand();\n        StockMovementItem item = new StockMovementItem();\n        item.setSignature(model.getSignature());\n        item.setMovementDate(new Date());\n        item.setMovementQuantity(Math.abs(inventory - stockOnHand));\n        item.setStockOnHand(inventory);\n        item.setStockCard(stockCard);\n\n        if (inventory > stockOnHand) {\n            item.setReason(MovementReasonManager.INVENTORY_POSITIVE);\n            item.setMovementType(MovementReasonManager.MovementType.POSITIVE_ADJUST);\n        } else if (inventory < stockOnHand) {\n            item.setReason(MovementReasonManager.INVENTORY_NEGATIVE);\n            item.setMovementType(MovementReasonManager.MovementType.NEGATIVE_ADJUST);\n        } else {\n            item.setReason(MovementReasonManager.INVENTORY);\n            item.setMovementType(MovementReasonManager.MovementType.PHYSICAL_INVENTORY);\n        }\n\n        item.populateLotAndResetStockOnHandOfLotAccordingPhysicalAdjustment(model.getExistingLotMovementViewModelList(), model.getNewLotMovementViewModelList());\n\n        return item;\n    }", "signature": "StockMovementItem calculateAdjustment(InventoryViewModel model, StockCard stockCard)", "full_signature": "protected StockMovementItem calculateAdjustment(InventoryViewModel model, StockCard stockCard)", "class_method_signature": "PhysicalInventoryPresenter.calculateAdjustment(InventoryViewModel model, StockCard stockCard)", "testcase": false, "constructor": false, "invocations": ["getLotListQuantityTotalAmount", "getStockOnHand", "setSignature", "getSignature", "setMovementDate", "setMovementQuantity", "abs", "setStockOnHand", "setStockCard", "setReason", "setMovementType", "setReason", "setMovementType", "setReason", "setMovementType", "populateLotAndResetStockOnHandOfLotAccordingPhysicalAdjustment", "getExistingLotMovementViewModelList", "getNewLotMovementViewModelList"]}, "repository": {"repo_id": 39063523, "url": "https://github.com/SIGLUS/lmis-moz-mobile", "stars": 15, "created": "7/14/2015 8:34:48 AM +00:00", "updates": "2020-01-07T14:05:00+00:00", "fork": "False", "license": "licensed"}}