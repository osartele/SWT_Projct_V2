java/org/openlmis/core/presenter/PhysicalInventoryPresenterTest.java"}, "test_case": {"identifier": "shouldSaveInventoryWhenCompletePhysicalInventory", "parameters": "()", "modifiers": "@Test public", "return": "void", "body": "@Test\n    public void shouldSaveInventoryWhenCompletePhysicalInventory() throws Exception {\n\n        TestSubscriber<List<InventoryViewModel>> subscriber = new TestSubscriber<>();\n        presenter.getInventoryViewModelList().clear();\n        presenter.getInventoryViewModelList().addAll(getStockCardViewModels());\n        String sign = \"signature\";\n        Observable observable = presenter.doInventory(sign);\n        observable.subscribe(subscriber);\n\n        subscriber.awaitTerminalEvent();\n\n        verify(mockInventoryRepository).save(any(Inventory.class));\n    }", "signature": "void shouldSaveInventoryWhenCompletePhysicalInventory()", "full_signature": "@Test public void shouldSaveInventoryWhenCompletePhysicalInventory()", "class_method_signature": "PhysicalInventoryPresenterTest.shouldSaveInventoryWhenCompletePhysicalInventory()", "testcase": true, "constructor": false, "invocations": ["clear", "getInventoryViewModelList", "addAll", "getInventoryViewModelList", "getStockCardViewModels", "doInventory", "subscribe", "awaitTerminalEvent", "save", "verify", "any"]}, "focal_class": {"identifier": "PhysicalInventoryPresenter", "superclass": "extends InventoryPresenter", "interfaces": "", "fields": [{"original_string": "@Inject\n    StockService stockService;", "modifier": "@Inject", "type": "StockService", "declarator": "stockService", "var_name": "stockService"}, {"original_string": "@Inject\n    StockMovementRepository movementRepository;", "modifier": "@Inject", "type": "StockMovementRepository", "declarator": "movementRepository", "var_name": "movementRepository"}], "methods": [{"identifier": "loadInventory", "parameters": "()", "modifiers": "@Override public", "return": "Observable<List<InventoryViewModel>>", "signature": "Observable<List<InventoryViewModel>> loadInventory()", "full_signature": "@Override public Observable<List<InventoryViewModel>> loadInventory()", "class_method_signature": "PhysicalInventoryPresenter.loadInventory()", "testcase": false, "constructor": false}, {"identifier": "convertStockCardsToStockCardViewModels", "parameters": "(List<StockCard> validStockCardsForPhysicalInventory)", "modifiers": "private", "return": "List<InventoryViewModel>", "signature": "List<InventoryViewModel> convertStockCardsToStockCardViewModels(List<StockCard> validStockCardsForPhysicalInventory)", "full_signature": "private List<InventoryViewModel> convertStockCardsToStockCardViewModels(List<StockCard> validStockCardsForPhysicalInventory)", "class_method_signature": "PhysicalInventoryPresenter.convertStockCardsToStockCardViewModels(List<StockCard> validStockCardsForPhysicalInventory)", "testcase": false, "constructor": false}, {"identifier": "getValidStockCardsForPhysicalInventory", "parameters": "()", "modifiers": "protected", "return": "List<StockCard>", "signature": "List<StockCard> getValidStockCardsForPhysicalInventory()", "full_signature": "protected List<StockCard> getValidStockCardsForPhysicalInventory()", "class_method_signature": "PhysicalInventoryPresenter.getValidStockCardsForPhysicalInventory()", "testcase": false, "constructor": false}, {"identifier": "restoreDraftInventory", "parameters": "()", "modifiers": "protected", "return": "void", "signature": "void restoreDraftInventory()", "full_signature": "protected void restoreDraftInventory()", "class_method_signature": "PhysicalInventoryPresenter.restoreDraftInventory()", "testcase": false, "constructor": false}, {"identifier": "populateLotMovementModelWithExistingSoh", "parameters": "(InventoryViewModel viewModel)", "modifiers": "private", "return": "void", "signature": "void populateLotMovementModelWithExistingSoh(InventoryViewModel viewModel)", "full_signature": "private void populateLotMovementModelWithExistingSoh(InventoryViewModel viewModel)", "class_method_signature": "PhysicalInventoryPresenter.populateLotMovementModelWithExistingSoh(InventoryViewModel viewModel)", "testcase": false, "constructor": false}, {"identifier": "calculateAdjustment", "parameters": "(InventoryViewModel model, StockCard stockCard)", "modifiers": "protected", "return": "StockMovementItem", "signature": "StockMovementItem calculateAdjustment(InventoryViewModel model, StockCard stockCard)", "full_signature": "protected StockMovementItem calculateAdjustment(InventoryViewModel model, StockCard stockCard)", "class_method_signature": "PhysicalInventoryPresenter.calculateAdjustment(InventoryViewModel model, StockCard stockCard)", "testcase": false, "constructor": false}, {"identifier": "saveDraftInventoryObservable", "parameters": "()", "modifiers": "public", "return": "Observable<Object>", "signature": "Observable<Object> saveDraftInventoryObservable()", "full_signature": "public Observable<Object> saveDraftInventoryObservable()", "class_method_signature": "PhysicalInventoryPresenter.saveDraftInventoryObservable()", "testcase": false, "constructor": false}, {"identifier": "doInventory", "parameters": "(final String sign)", "modifiers": "public", "return": "Observable<Object>", "signature": "Observable<Object> doInventory(final String sign)", "full_signature": "public Observable<Object> doInventory(final String sign)", "class_method_signature": "PhysicalInventoryPresenter.doInventory(final String sign)", "testcase": false, "constructor": false}, {"identifier": "hasInversionDateBetweenMovementAndDB", "parameters": "(List<StockMovementItem> newestEachMovementItems, Date now)", "modifiers": "private", "return": "boolean", "signature": "boolean hasInversionDateBetweenMovementAndDB(List<StockMovementItem> newestEachMovementItems, Date now)", "full_signature": "private boolean hasInversionDateBetweenMovementAndDB(List<StockMovementItem> newestEachMovementItems, Date now)", "class_method_signature": "PhysicalInventoryPresenter.hasInversionDateBetweenMovementAndDB(List<StockMovementItem> newestEachMovementItems, Date now)", "testcase": false, "constructor": false}, {"identifier": "saveInventoryDate", "parameters": "()", "modifiers": "private", "return": "void", "signature": "void saveInventoryDate()", "full_signature": "private void saveInventoryDate()", "class_method_signature": "PhysicalInventoryPresenter.saveInventoryDate()", "testcase": false, "constructor": false}, {"identifier": "setExistingLotViewModels", "parameters": "(InventoryViewModel inventoryViewModel)", "modifiers": "private", "return": "void", "signature": "void setExistingLotViewModels(InventoryViewModel inventoryViewModel)", "full_signature": "private void setExistingLotViewModels(InventoryViewModel inventoryViewModel)", "class_method_signature": "PhysicalInventoryPresenter.setExistingLotViewModels(InventoryViewModel inventoryViewModel)", "testcase": false, "constructor": false}, {"identifier": "updateAvgMonthlyConsumption", "parameters": "()", "modifiers": "public", "return": "void", "signature": "void updateAvgMonthlyConsumption()", "full_signature": "public void updateAvgMonthlyConsumption()", "class_method_signature": "PhysicalInventoryPresenter.updateAvgMonthlyConsumption()", "testcase": false, "constructor": false}, {"identifier": "getCompleteCount", "parameters": "()", "modifiers": "public", "return": "int", "signature": "int getCompleteCount()", "full_signature": "public int getCompleteCount()", "class_method_signature": "PhysicalInventoryPresenter.getCompleteCount()", "testcase": false, "constructor": false}], "file": "app/src/main/java/org/openlmis/core/presenter/PhysicalInventoryPresenter.java"}, "focal_method": {"identifier": "doInventory", "parameters": "(final String sign)", "modifiers": "public", "return": "Observable<Object>", "body": "public Observable<Object> doInventory(final String sign) {\n        return Observable.create(subscriber -> {\n            try {\n                List<StockMovementItem> newestEachMovementItems = movementRepository.queryEachStockCardNewestMovement();\n                Date now = new Date();\n                for (InventoryViewModel viewModel : inventoryViewModelList) {\n                    viewModel.setSignature(sign);\n                    StockCard stockCard = viewModel.getStockCard();\n\n                    stockCard.setStockOnHand(viewModel.getLotListQuantityTotalAmount());\n\n                    if (stockCard.getStockOnHand() == 0) {\n                        stockCard.setExpireDates(\"\");\n                    }\n                    if (!hasInversionDateBetweenMovementAndDB(newestEachMovementItems, now)) {\n                        stockRepository.addStockMovementAndUpdateStockCard(calculateAdjustment(viewModel, stockCard));\n                    } else {\n                        throw new LMISException(LMISApp.getContext().getString(R.string.msg_invalid_stock_movement));\n                    }\n                }\n                inventoryRepository.clearDraft();\n                sharedPreferenceMgr.setLatestPhysicInventoryTime(DateUtil.formatDate(new Date(), DateUtil.DATE_TIME_FORMAT));\n                saveInventoryDate();\n\n                subscriber.onNext(null);\n                subscriber.onCompleted();\n            } catch (LMISException e) {\n                subscriber.onError(e);\n                new LMISException(e, \"doInventory\").reportToFabric();\n            }\n        }).subscribeOn(Schedulers.io()).observeOn(AndroidSchedulers.mainThread());\n    }", "signature": "Observable<Object> doInventory(final String sign)", "full_signature": "public Observable<Object> doInventory(final String sign)", "class_method_signature": "PhysicalInventoryPresenter.doInventory(final String sign)", "testcase": false, "constructor": false, "invocations": ["observeOn", "subscribeOn", "create", "queryEachStockCardNewestMovement", "setSignature", "getStockCard", "setStockOnHand", "getLotListQuantityTotalAmount", "getStockOnHand", "setExpireDates", "hasInversionDateBetweenMovementAndDB", "addStockMovementAndUpdateStockCard", "calculateAdjustment", "getString", "getContext", "clearDraft", "setLatestPhysicInventoryTime", "formatDate", "saveInventoryDate", "onNext", "onCompleted", "onError", "reportToFabric", "io", "mainThread"]}, "repository": {"repo_id": 39063523, "url": "https://github.com/SIGLUS/lmis-moz-mobile", "stars": 15, "created": "7/14/2015 8:34:48 AM +00:00", "updates": "2020-01-07T14:05:00+00:00", "fork": "False", "license": "licensed"}}