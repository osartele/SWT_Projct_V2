{"test_class": {"identifier": "MessageDispatcherTest", "superclass": "", "interfaces": "", "fields": [{"original_string": "private static final int QUEUE_CAPACITY = 128;", "modifier": "private static final", "type": "int", "declarator": "QUEUE_CAPACITY = 128", "var_name": "QUEUE_CAPACITY"}, {"original_string": "private ExecutorService executorService;", "modifier": "private", "type": "ExecutorService", "declarator": "executorService", "var_name": "executorService"}, {"original_string": "private CircularBlockingDeque<LazyMessage<std_msgs.Int32>> lazyMessages;", "modifier": "private", "type": "CircularBlockingDeque<LazyMessage<std_msgs.Int32>>", "declarator": "lazyMessages", "var_name": "lazyMessages"}, {"original_string": "private MessageFactory messageFactory;", "modifier": "private", "type": "MessageFactory", "declarator": "messageFactory", "var_name": "messageFactory"}], "file": "rosjava/rosjava/src/test/java/org/ros/internal/transport/queue/MessageDispatcherTest.java"}, "test_case": {"identifier": "testMessageOrder", "parameters": "()", "modifiers": "@Test public", "return": "void", "body": "@Test\n  public void testMessageOrder() throws InterruptedException {\n    int numberOfMessages = 100;\n    final CountDownLatch latch = new CountDownLatch(numberOfMessages);\n\n    MessageDispatcher<std_msgs.Int32> messageDispatcher =\n        new MessageDispatcher<std_msgs.Int32>(lazyMessages, executorService);\n    messageDispatcher.addListener(new MessageListener<std_msgs.Int32>() {\n      private AtomicInteger count = new AtomicInteger();\n\n      @Override\n      public void onNewMessage(Int32 message) {\n        if (this.count.compareAndSet(message.getData(), message.getData() + 1)) {\n          latch.countDown();\n        } else {\n          fail(String.format(\"Expected message data not equal to actual data: %d != %d\",\n              count.get(), message.getData()));\n        }\n        try {\n          // Sleeping allows the queue to fill up a bit by slowing down the\n          // consumer.\n          Thread.sleep(5);\n        } catch (InterruptedException e) {\n        }\n      }\n    }, QUEUE_CAPACITY);\n    executorService.execute(messageDispatcher);\n\n    for (int i = 0; i < numberOfMessages; i++) {\n      final int count = i;\n      std_msgs.Int32 message = messageFactory.newFromType(std_msgs.Int32._TYPE);\n      message.setData(count);\n      lazyMessages.addLast(new LazyMessage<std_msgs.Int32>(message));\n    }\n\n    assertTrue(latch.await(1, TimeUnit.SECONDS));\n  }", "signature": "void testMessageOrder()", "full_signature": "@Test public void testMessageOrder()", "class_method_signature": "MessageDispatcherTest.testMessageOrder()", "testcase": true, "constructor": false, "invocations": ["addListener", "compareAndSet", "getData", "getData", "countDown", "fail", "format", "get", "getData", "sleep", "execute", "newFromType", "setData", "addLast", "assertTrue", "await"]}, "focal_class": {"identifier": "MessageDispatcher", "superclass": "extends CancellableLoop", "interfaces": "", "fields": [{"original_string": "private static final boolean DEBUG = false;", "modifier": "private static final", "type": "boolean", "declarator": "DEBUG = false", "var_name": "DEBUG"}, {"original_string": "private static final Log log = LogFactory.getLog(MessageDispatcher.class);", "modifier": "private static final", "type": "Log", "declarator": "log = LogFactory.getLog(MessageDispatcher.class)", "var_name": "log"}, {"original_string": "private final CircularBlockingDeque<LazyMessage<T>> lazyMessages;", "modifier": "private final", "type": "CircularBlockingDeque<LazyMessage<T>>", "declarator": "lazyMessages", "var_name": "lazyMessages"}, {"original_string": "private final ListenerGroup<MessageListener<T>> messageListeners;", "modifier": "private final", "type": "ListenerGroup<MessageListener<T>>", "declarator": "messageListeners", "var_name": "messageListeners"}, {"original_string": "private final Object mutex;", "modifier": "private final", 