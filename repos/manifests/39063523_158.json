lse}, {"identifier": "monthlyCheckAllMovement", "parameters": "()", "modifiers": "private", "return": "List<StockCard>", "signature": "List<StockCard> monthlyCheckAllMovement()", "full_signature": "private List<StockCard> monthlyCheckAllMovement()", "class_method_signature": "StockService.monthlyCheckAllMovement()", "testcase": false, "constructor": false}, {"identifier": "immediatelyUpdateAvgMonthlyConsumption", "parameters": "()", "modifiers": "public", "return": "void", "signature": "void immediatelyUpdateAvgMonthlyConsumption()", "full_signature": "public void immediatelyUpdateAvgMonthlyConsumption()", "class_method_signature": "StockService.immediatelyUpdateAvgMonthlyConsumption()", "testcase": false, "constructor": false}, {"identifier": "calculateAverageMonthlyConsumption", "parameters": "(StockCard stockCard)", "modifiers": "protected", "return": "float", "signature": "float calculateAverageMonthlyConsumption(StockCard stockCard)", "full_signature": "protected float calculateAverageMonthlyConsumption(StockCard stockCard)", "class_method_signature": "StockService.calculateAverageMonthlyConsumption(StockCard stockCard)", "testcase": false, "constructor": false}, {"identifier": "hasStockOutTotoalIssue", "parameters": "(Long totalIssuesEachMonth)", "modifiers": "private", "return": "Boolean", "signature": "Boolean hasStockOutTotoalIssue(Long totalIssuesEachMonth)", "full_signature": "private Boolean hasStockOutTotoalIssue(Long totalIssuesEachMonth)", "class_method_signature": "StockService.hasStockOutTotoalIssue(Long totalIssuesEachMonth)", "testcase": false, "constructor": false}, {"identifier": "getTotalIssues", "parameters": "(List<Long> issuePerMonths)", "modifiers": "private", "return": "long", "signature": "long getTotalIssues(List<Long> issuePerMonths)", "full_signature": "private long getTotalIssues(List<Long> issuePerMonths)", "class_method_signature": "StockService.getTotalIssues(List<Long> issuePerMonths)", "testcase": false, "constructor": false}, {"identifier": "calculateTotalIssuesPerPeriod", "parameters": "(StockCard stockCard, Period period)", "modifiers": "private", "return": "Long", "signature": "Long calculateTotalIssuesPerPeriod(StockCard stockCard, Period period)", "full_signature": "private Long calculateTotalIssuesPerPeriod(StockCard stockCard, Period period)", "class_method_signature": "StockService.calculateTotalIssuesPerPeriod(StockCard stockCard, Period period)", "testcase": false, "constructor": false}, {"identifier": "periodHasStockOut", "parameters": "(StockCard stockCard, List<StockMovementItem> stockMovementItems, final Period period)", "modifiers": "private", "return": "boolean", "signature": "boolean periodHasStockOut(StockCard stockCard, List<StockMovementItem> stockMovementItems, final Period period)", "full_signature": "private boolean periodHasStockOut(StockCard stockCard, List<StockMovementItem> stockMovementItems, final Period period)", "class_method_signature": "StockService.periodHasStockOut(StockCard stockCard, List<StockMovementItem> stockMovementItems, final Period period)", "testcase": false, "constructor": false}, {"identifier": "hasStockOutInThisPeriod", "parameters": "(List<StockMovementItem> stockMovementItems)", "modifiers": "private", "return": "boolean", "signature": "boolean hasStockOutInThisPeriod(List<StockMovementItem> stockMovementItems)", "full_signature": "private boolean hasStockOutInThisPeriod(List<StockMovementItem> stockMovementItems)", "class_method_signature": "StockService.hasStockOutInThisPeriod(List<StockMovementItem> stockMovementItems)", "testcase": false, "constructor": false}, {"identifier": "isStockOutStatusInherited", "parameters": "(StockCard stockCard, final Period period)", "modifiers": "private", "return": "boolean", "signature": "boolean isStockOutStatusInherited(StockCard stockCard, final Period period)", "full_signature": "private boolean isStockOutStatusInherited(StockCard stockCard, final Period period)", "class_method_signature": "StockService.isStockOutStatusInherited(StockCard stockCard, final Period period)", "testcase": false, "constructor": false}], "file": "app/src/main/java/org/openlmis/core/model/service/StockService.java"}, "focal_method": {"identifier": "calculateAverageMonthlyConsumption", "parameters": "(StockCard stockCard)", "modifiers": "protected", "return": "float", "body": "protected float calculateAverageMonthlyConsumption(StockCard stockCard) {\n        Date firstPeriodBegin;\n        try {\n            firstPeriodBegin = queryFirstPeriodBegin(stockCard);\n        } catch (LMISException e) {\n            new LMISException(e, \"StockService:calculateAverage\").reportToFabric();\n            return -1;\n        }\n        if (firstPeriodBegin == null) {\n            return -1;\n        }\n\n        List<Long> issuePerMonths = new ArrayList<>();\n        Period period = Period.of(today());\n        int periodQuantity = DateUtil.calculateDateMonthOffset(firstPeriodBegin, period.getBegin().toDate());\n\n        for (int i = 0; i < periodQuantity; i++) {\n            period = period.previous();\n            Long totalIssuesEachMonth = calculateTotalIssuesPerPeriod(stockCard, period);\n\n            if (hasStockOutTotoalIssue(totalIssuesEachMonth)) {\n                continue;\n            }\n\n            issuePerMonths.add(totalIssuesEachMonth);\n            if (issuePerMonths.size() == HIGH_STOCK_CALCULATE_MONTH_QUANTITY) {\n                break;\n            }\n        }\n        if (issuePerMonths.size() < 1) {\n            return -1;\n        }\n\n        return getTotalIssues(issuePerMonths) * 1f / issuePerMonths.size();\n    }", "signature": "float calculateAverageMonthlyConsumption(StockCard stockCard)", "full_signature": "protected float calculateAverageMonthlyConsumption(StockCard stockCard)", "class_method_signature": "StockService.calculateAverageMonthlyConsumption(StockCard stockCard)", "testcase": false, "constructor": false, "invocations": ["queryFirstPeriodBegin", "reportToFabric", "of", "today", "calculateDateMonthOffset", "toDate", "getBegin", "previous", "calculateTotalIssuesPerPeriod", "hasStockOutTotoalIssue", "add", "size", "size", "getTotalIssues", "size"]}, "repository": {"repo_id": 39063523, "url": "https://github.com/SIGLUS/lmis-moz-mobile", "stars": 15, "created": "7/14/2015 8:34:48 AM +00:00", "updates": "2020-01-07T14:05:00+00:00", "fork": "False", "license": "licensed"}}