tly() throws LMISException {\n        //given\n        StockCard stockCard = new StockCard();\n        stockCard.setProduct(getRandomProduct());\n        stockCard.setStockOnHand(200);\n        stockService.stockRepository.createOrUpdate(stockCard);\n\n        createMovementItem(ISSUE, 100, stockCard, new Date(), lastForthMonthDate, false);//4 month ago soh:100\n\n        createMovementItem(ISSUE, 100, stockCard, new Date(), lastThirdMonthDate, false);//3 month ago soh:0\n\n        createMovementItem(RECEIVE, 400, stockCard, new Date(), lastSecondMonthDate, false);//2 month ago soh:400\n        createMovementItem(ISSUE, 100, stockCard, new Date(), lastSecondMonthDate, false);//2 month ago soh:300\n\n        createMovementItem(ISSUE, 100, stockCard, new Date(), lastFirstMonthDate, false);//1 month ago soh:200\n\n        //when\n        float averageMonthlyConsumption = stockService.calculateAverageMonthlyConsumption(stockCard);\n\n        //then\n        assertThat(averageMonthlyConsumption, is(100F));\n    }", "signature": "void shouldCalculateAverageMonthlyConsumptionWithStockOutCorrectly()", "full_signature": "@Test public void shouldCalculateAverageMonthlyConsumptionWithStockOutCorrectly()", "class_method_signature": "StockServiceTest.shouldCalculateAverageMonthlyConsumptionWithStockOutCorrectly()", "testcase": true, "constructor": false, "invocations": ["setProduct", "getRandomProduct", "setStockOnHand", "createOrUpdate", "createMovementItem", "createMovementItem", "createMovementItem", "createMovementItem", "createMovementItem", "calculateAverageMonthlyConsumption", "assertThat", "is"]}, "focal_class": {"identifier": "StockService", "superclass": "", "interfaces": "", "fields": [{"original_string": "private final int HIGH_STOCK_CALCULATE_MONTH_QUANTITY = 3;", "modifier": "private final", "type": "int", "declarator": "HIGH_STOCK_CALCULATE_MONTH_QUANTITY = 3", "var_name": "HIGH_STOCK_CALCULATE_MONTH_QUANTITY"}, {"original_string": "private final int LOW_STOCK_CAL