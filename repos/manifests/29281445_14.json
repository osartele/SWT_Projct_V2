{"test_class": {"identifier": "GlobberTest", "superclass": "", "interfaces": "", "fields": [], "file": "blaze-core/src/test/java/com/fizzed/blaze/util/GlobberTest.java"}, "test_case": {"identifier": "containsUnescapedChars", "parameters": "()", "modifiers": "@Test public", "return": "void", "body": "@Test\n    public void containsUnescapedChars() {\n        char[] specialChars = new char[] { '*', '{', '}' };\n        \n        boolean result;\n        \n        result = Globber.containsUnescapedChars(\"\", specialChars);\n        assertThat(result, is(false));\n        \n        result = Globber.containsUnescapedChars(\"a\", specialChars);\n        assertThat(result, is(false));\n        \n        result = Globber.containsUnescapedChars(\"*\", specialChars);\n        assertThat(result, is(true));\n        \n        result = Globber.containsUnescapedChars(\"{\", specialChars);\n        assertThat(result, is(true));\n        \n        result = Globber.containsUnescapedChars(\"}\", specialChars);\n        assertThat(result, is(true));\n        \n        // escaped versions\n        \n        result = Globber.containsUnescapedChars(\"\\\\*\", specialChars);\n        assertThat(result, is(false));\n        \n        result = Globber.containsUnescapedChars(\"\\\\*\\\\{.java\\\\}\", specialChars);\n        assertThat(result, is(false));\n    }", "signature": "void containsUnescapedChars()", "full_signature": "@Test public void containsUnescapedChars()", "class_method_signature": "GlobberTest.containsUnescapedChars()", "testcase": true, "constructor": false, "invocations": ["containsUnescapedChars", "assertThat", "is", "containsUnescapedChars", "assertThat", "is", "containsUnescapedChars", "assertThat", "is", "containsUnescapedChars", "assertThat", "is", "containsUnescapedChars", "assertThat", "is", "containsUnescapedChars", "assertThat", "is", "containsUnescapedChars", "assertThat", "is"]}, "focal_class": {"identifier": "Globber", "superclass": "", "interfaces": "", "field