ovements()", "full_signature": "private void fetchLatestOneMonthMovements()", "class_method_signature": "SyncDownManager.fetchLatestOneMonthMovements()", "testcase": false, "constructor": false}, {"identifier": "errorMessage", "parameters": "(int code)", "modifiers": "private", "return": "String", "signature": "String errorMessage(int code)", "full_signature": "private String errorMessage(int code)", "class_method_signature": "SyncDownManager.errorMessage(int code)", "testcase": false, "constructor": false}], "file": "app/src/main/java/org/openlmis/core/service/SyncDownManager.java"}, "focal_method": {"identifier": "updateDeactivateProductNotifyList", "parameters": "(Product product)", "modifiers": "protected", "return": "void", "body": "protected void updateDeactivateProductNotifyList(Product product) throws LMISException {\n        Product existingProduct = productRepository.getByCode(product.getCode());\n\n        if (existingProduct == null) {\n            return;\n        }\n\n        if (product.isActive() == existingProduct.isActive()) {\n            return;\n        }\n        if (product.isActive()) {\n            sharedPreferenceMgr.removeShowUpdateBannerTextWhenReactiveProduct(existingProduct.getPrimaryName());\n            return;\n        }\n\n        StockCard stockCard = stockRepository.queryStockCardByProductId(existingProduct.getId());\n        if (stockCard == null) {\n            return;\n        }\n\n        if (stockCard.getProduct().isArchived()) {\n            return;\n        }\n\n        if (stockCard.getStockOnHand() == 0) {\n            sharedPreferenceMgr.setIsNeedShowProductsUpdateBanner(true, product.getPrimaryName());\n        }\n    }", "signature": "void updateDeactivateProductNotifyList(Product product)", "full_signature": "protected void updateDeactivateProductNotifyList(Product product)", "class_method_signature": "SyncDownManager.updateDeactivateProductNotifyList(Product product)", "testcase": false, "constructor": false, "invoca