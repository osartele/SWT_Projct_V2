ram", "parameters": "(final Period period)", "modifiers": "public", "return": "Observable<List<ImplementationReportViewModel>>", "signature": "Observable<List<ImplementationReportViewModel>> getImplementationViewModelsForCurrentMalariaProgram(final Period period)", "full_signature": "public Observable<List<ImplementationReportViewModel>> getImplementationViewModelsForCurrentMalariaProgram(final Period period)", "class_method_signature": "MalariaDataReportFormPresenter.getImplementationViewModelsForCurrentMalariaProgram(final Period period)", "testcase": false, "constructor": false}, {"identifier": "getMalariaProgram", "parameters": "()", "modifiers": "public", "return": "MalariaProgram", "signature": "MalariaProgram getMalariaProgram()", "full_signature": "public MalariaProgram getMalariaProgram()", "class_method_signature": "MalariaDataReportFormPresenter.getMalariaProgram()", "testcase": false, "constructor": false}, {"identifier": "regenerateImplementationModels", "parameters": "(ImplementationReportViewModel updatedViewModel)", "modifiers": "public", "return": "List<ImplementationReportViewModel>", "signature": "List<ImplementationReportViewModel> regenerateImplementationModels(ImplementationReportViewModel updatedViewModel)", "full_signature": "public List<ImplementationReportViewModel> regenerateImplementationModels(ImplementationReportViewModel updatedViewModel)", "class_method_signature": "MalariaDataReportFormPresenter.regenerateImplementationModels(ImplementationReportViewModel updatedViewModel)", "testcase": false, "constructor": false}, {"identifier": "getIndexOfModel", "parameters": "(ImplementationReportViewModel updatedViewModel)", "modifiers": "private", "return": "int", "signature": "int getIndexOfModel(ImplementationReportViewModel updatedViewModel)", "full_signature": "private int getIndexOfModel(ImplementationReportViewModel updatedViewModel)", "class_method_signature": "MalariaDataReportFormPresenter.getIndexOfModel(ImplementationReportViewModel updatedViewModel)", "testcase": false, "constructor": false}, {"identifier": "generateTotalViewModel", "parameters": "(ImplementationReportViewModel usImplementation,\n                                                                 ImplementationReportViewModel apeImplementation)", "modifiers": "private", "return": "ImplementationReportViewModel", "signature": "ImplementationReportViewModel generateTotalViewModel(ImplementationReportViewModel usImplementation,\n                                                                 ImplementationReportViewModel apeImplementation)", "full_signature": "private ImplementationReportViewModel generateTotalViewModel(ImplementationReportViewModel usImplementation,\n                                                                 ImplementationReportViewModel apeImplementation)", "class_method_signature": "MalariaDataReportFormPresenter.generateTotalViewModel(ImplementationReportViewModel usImplementation,\n                                                                 ImplementationReportViewModel apeImplementation)", "testcase": false, "constructor": false}, {"identifier": "onSaveForm", "parameters": "(final ViaReportStatus status, final String sign)", "modifiers": "public", "return": "Observable<MalariaProgram>", "signature": "Observable<MalariaProgram> onSaveForm(final ViaReportStatus status, final String sign)", "full_signature": "public Observable<MalariaProgram> onSaveForm(final ViaReportStatus status, final String sign)", "class_method_signature": "MalariaDataReportFormPresenter.onSaveForm(final ViaReportStatus status, final String sign)", "testcase": false, "constructor": false}, {"identifier": "deleteDraft", "parameters": "()", "modifiers": "@Override public", "return": "void", "signature": "void deleteDraft()", "full_signature": "@Override public void deleteDraft()", "class_method_signature": "MalariaDataReportFormPresenter.deleteDraft()", "testcase": false, "constructor": false}, {"identifier": "isDraft", "parameters": "()", "modifiers": "@Override public", "return": "boolean", "signature": "boolean isDraft()", "full_signature": "@Override public boolean isDraft()", "class_method_signature": "MalariaDataReportFormPresenter.isDraft()", "testcase": false, "constructor": false}, {"identifier": "addSignature", "parameters": "(String signature)", "modifiers": "@Override protected", "return": "void", "signature": "void addSignature(String signature)", "full_signature": "@Override protected void addSignature(String signature)", "class_method_signature": "MalariaDataReportFormPresenter.addSignature(String signature)", "testcase": false, "constructor": false}, {"identifier": "isSubmittedForApproval", "parameters": "()", "modifiers": "public", "return": "boolean", "signature": "boolean isSubmittedForApproval()", "full_signature": "public boolean isSubmittedForApproval()", "class_method_signature": "MalariaDataReportFormPresenter.isSubmittedForApproval()", "testcase": false, "constructor": false}], "file": "app/src/main/java/org/openlmis/core/presenter/MalariaDataReportFormPresenter.java"}, "focal_method": {"identifier": "onSaveForm", "parameters": "(final ViaReportStatus status, final String sign)", "modifiers": "public", "return": "Observable<MalariaProgram>", "body": "public Observable<MalariaProgram> onSaveForm(final ViaReportStatus status, final String sign) {\n        return Observable.create((Observable.OnSubscribe<MalariaProgram>) subscriber -> {\n            try {\n                MalariaProgram malariaProgram = getMalariaProgram();\n                malariaProgram.setStatus(status);\n                if (status.equals(ViaReportStatus.SUBMITTED)) {\n                    malariaProgram.setVerifiedBy(sign);\n                } else {\n                    malariaProgram.setCreatedBy(sign);\n                }\n                patientDataService.save(malariaProgram);\n                subscriber.onNext(malariaProgram);\n                subscriber.onCompleted();\n            } catch (Exception e) {\n                subscriber.onError(e);\n                new LMISException(e, \"MalariaData:.onSaveForm\").reportToFabric();\n\n            }\n        }).observeOn(AndroidSchedulers.mainThread()).subscribeOn(Schedulers.io());\n    }", "signature": "Observable<MalariaProgram> onSaveForm(final ViaReportStatus status, final String sign)", "full_signature": "public Observable<MalariaProgram> onSaveForm(final ViaReportStatus status, final String sign)", "class_method_signature": "MalariaDataReportFormPresenter.onSaveForm(final ViaReportStatus status, final String sign)", "testcase": false, "constructor": false, "invocations": ["subscribeOn", "observeOn", "create", "getMalariaProgram", "setStatus", "equals", "setVerifiedBy", "setCreatedBy", "save", "onNext", "onCompleted", "onError", "reportToFabric", "mainThread", "io"]}, "repository": {"repo_id": 39063523, "url": "https://github.com/SIGLUS/lmis-moz-mobile", "stars": 15, "created": "7/14/2015 8:34:48 AM +00:00", "updates": "2020-01-07T14:05:00+00:00", "fork": "False", "license": "licensed"}}