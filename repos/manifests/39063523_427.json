.size() > 0) {\n            editPharmacyTexts.get(editPharmacyTexts.size() - 1).setImeOptions(EditorInfo.IME_ACTION_DONE);\n        }\n        post(() -> initAdultAndChildrenHeaderHeight());\n    }", "signature": "void initView(TextView totalView, TextView totalPharmacy, TextView tvTotalPharmacyTitle, MMIARequisitionPresenter presenter)", "full_signature": "public void initView(TextView totalView, TextView totalPharmacy, TextView tvTotalPharmacyTitle, MMIARequisitionPresenter presenter)", "class_method_signature": "MMIARegimeList.initView(TextView totalView, TextView totalPharmacy, TextView tvTotalPharmacyTitle, MMIARequisitionPresenter presenter)", "testcase": false, "constructor": false, "invocations": ["isEmpty", "getRegimenThreeLineListWrapper", "getRnRForm", "getRegimenItemListWrapper", "getRnRForm", "initCategoryList", "size", "addItemView", "get", "isCustomEnable", "addAdultBtnView", "size", "addItemView", "get", "size", "isCustomEnable", "addPaediatricsBtnView", "setText", "valueOf", "getTotal", "setText", "valueOf", "getTotal", "setImeOptions", "get", "size", "size", "setImeOptions", "get", "size", "post", "initAdultAndChildrenHeaderHeight"]}, "repository": {"repo_id": 39063523, "url": "https://github.com/SIGLUS/lmis-moz-mobile", "stars": 15, "created": "7/14/2015 8:34:48 AM +00:00", "updates": "2020-01-07T14:05:00+00:00", "fork": "False", "license": "licensed"}}