ntItemsToStockMovementEntriesForSync", "parameters": "(final String facilityId,\n                                                                                            List<StockMovementItem> stockMovementItems)", "modifiers": "private", "return": "List<StockMovementEntry>", "signature": "List<StockMovementEntry> convertStockMovementItemsToStockMovementEntriesForSync(final String facilityId,\n                                                                                            List<StockMovementItem> stockMovementItems)", "full_signature": "private List<StockMovementEntry> convertStockMovementItemsToStockMovementEntriesForSync(final String facilityId,\n                                                                                            List<StockMovementItem> stockMovementItems)", "class_method_signature": "SyncUpManager.convertStockMovementItemsToStockMovementEntriesForSync(final String facilityId,\n                                                                                            List<StockMovementItem> stockMovementItems)", "testcase": false, "constructor": false}, {"identifier": "markStockDataSynced", "parameters": "(List<StockMovementItem> stockMovementItems)", "modifiers": "private", "return": "void", "signature": "void markStockDataSynced(List<StockMovementItem> stockMovementItems)", "full_signature": "private void markStockDataSynced(List<StockMovementItem> stockMovementItems)", "class_method_signature": "SyncUpManager.markStockDataSynced(List<StockMovementItem> stockMovementItems)", "testcase": false, "constructor": false}, {"identifier": "markRnrFormSynced", "parameters": "(RnRForm rnRForm)", "modifiers": "private", "return": "void", "signature": "void markRnrFormSynced(RnRForm rnRForm)", "full_signature": "private void markRnrFormSynced(RnRForm rnRForm)", "class_method_signature": "SyncUpManager.markRnrFormSynced(RnRForm rnRForm)", "testcase": false, "constructor": false}, {"identifier": "syncRapidTestForms", "parameters": "()", "modifiers": "public", "return": "void", "signature": "void syncRapidTestForms()", "full_signature": "public void syncRapidTestForms()", "class_method_signature": "SyncUpManager.syncRapidTestForms()", "testcase": false, "constructor": false}, {"identifier": "fakeSyncRapidTestForms", "parameters": "()", "modifiers": "public", "return": "void", "signature": "void fakeSyncRapidTestForms()", "full_signature": "public void fakeSyncRapidTestForms()", "class_method_signature": "SyncUpManager.fakeSyncRapidTestForms()", "testcase": false, "constructor": false}, {"identifier": "markProgramDataFormsSynced", "parameters": "(ProgramDataForm programDataForm)", "modifiers": "private", "return": "void", "signature": "void markProgramDataFormsSynced(ProgramDataForm programDataForm)", "full_signature": "private void markProgramDataFormsSynced(ProgramDataForm programDataForm)", "class_method_signature": "SyncUpManager.markProgramDataFormsSynced(ProgramDataForm programDataForm)", "testcase": false, "constructor": false}], "file": "app/src/main/java/org/openlmis/core/service/SyncUpManager.java"}, "focal_method": {"identifier": "syncDeleteMovement", "parameters": "()", "modifiers": "public", "return": "boolean", "body": "public boolean syncDeleteMovement() {\n        int unitCount = 6;\n        String facilityId = UserInfoMgr.getInstance().getUser().getFacilityId();\n        List<DirtyDataItemInfo> itemInfos = dirtyDataRepository.listunSyced();\n        List<String> errorProducts = new ArrayList<>();\n\n        if (!CollectionUtils.isEmpty(itemInfos)) {\n            List<DirtyDataItemEntry> entries = FluentIterable.from(itemInfos).transform(new Function<DirtyDataItemInfo, DirtyDataItemEntry>() {\n                @Nullable\n                @Override\n                public DirtyDataItemEntry apply(@Nullable DirtyDataItemInfo dirtyDataItemInfo) {\n                    return new DirtyDataItemEntry(dirtyDataItemInfo.getProductCode(), dirtyDataItemInfo.getJsonData());\n                }\n            }).toList();\n\n            for (int start = 0; start < entries.size(); ) {\n                int end = (start + unitCount) >= entries.size() ? entries.size() : start + unitCount;\n                List<DirtyDataItemEntry> sub = entries.subList(start, end);\n                try {\n                    SyncUpDeletedMovementResponse response = lmisRestApi.syncUpDeletedData(Long.parseLong(facilityId), sub);\n                    errorProducts.addAll(response.getErrorCodes());\n                } catch (LMISException e) {\n                    e.printStackTrace();\n                }\n                start += unitCount;\n            }\n            List<String> shouldMarkedToSynced = FluentIterable.from(itemInfos).transform(new Function<DirtyDataItemInfo, String>() {\n                @Nullable\n                @Override\n                public String apply(@Nullable DirtyDataItemInfo dirtyDataItemInfo) {\n                    return dirtyDataItemInfo.getProductCode();\n                }\n            }).filter(s -> !errorProducts.contains(s)).toList();\n            for (DirtyDataItemInfo item : itemInfos) {\n                if (shouldMarkedToSynced.contains(item.getProductCode())) {\n                    item.setSynced(true);\n                    dirtyDataRepository.save(item);\n                }\n            }\n            return errorProducts.size() == 0;\n        } else {\n            return true;\n        }\n    }", "signature": "boolean syncDeleteMovement()", "full_signature": "public boolean syncDeleteMovement()", "class_method_signature": "SyncUpManager.syncDeleteMovement()", "testcase": false, "constructor": false, "invocations": ["getFacilityId", "getUser", "getInstance", "listunSyced", "isEmpty", "toList", "transform", "from", "getProductCode", "getJsonData", "size", "size", "size", "subList", "syncUpDeletedData", "parseLong", "addAll", "getErrorCodes", "printStackTrace", "toList", "filter", "transform", "from", "getProductCode", "contains", "contains", "getProductCode", "setSynced", "save", "size"]}, "repository": {"repo_id": 39063523, "url": "https://github.com/SIGLUS/lmis-moz-mobile", "stars": 15, "created": "7/14/2015 8:34:48 AM +00:00", "updates": "2020-01-07T14:05:00+00:00", "fork": "False", "license": "licensed"}}