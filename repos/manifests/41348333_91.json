st = context.getInputPorts();\n      if (inputPortList != null && !inputPortList.isEmpty()) {\n        DefaultPartition.assignPartitionKeys(newPartitions, inputPortList.iterator().next());\n      }\n    } else {\n      // define partitions is being called again\n      if (context.getParallelPartitionCount() != 0) {\n        newPartitions = repartitionParallel(partitions, context);\n      } else if (partition.getPartitionKeys().isEmpty()) {\n        newPartitions = repartitionInputOperator(partitions);\n      } else {\n        newPartitions = repartition(partitions);\n      }\n    }\n\n    logger.debug(\"new partition size {}\", newPartitions.size());\n    return newPartitions;\n  }", "signature": "Collection<Partition<T>> definePartitions(Collection<Partition<T>> partitions, PartitioningContext context)", "full_signature": "@Override public Collection<Partition<T>> definePartitions(Collection<Partition<T>> partitions, PartitioningContext context)", "class_method_signature": "StatelessPartitioner.definePartitions(Collection<Partition<T>> partitions, PartitioningContext context)", "testcase": false, "constructor": false, "invocations": ["getRequiredPartitionCount", "debug", "size", "next", "iterator", "getStats", "next", "iterator", "newArrayList", "add", "getPartitionedInstance", "getInputPorts", "isEmpty", "assignPartitionKeys", "next", "iterator", "getParallelPartitionCount", "repartitionParallel", "isEmpty", "getPartitionKeys", "repartitionInputOperator", "repartition", "debug", "size"]}, "repository": {"repo_id": 41348333, "url": "https://github.com/apache/attic-apex-core", "language": "Java", "is_fork": false, "fork_count": 181, "stargazer_count": 346, "size": 14734, "license": "licensed"}}