.refreshDate(inventories);\n\n        for (SelectInventoryViewModel selectInventoryViewModel : inventories) {\n            if (selectInventoryViewModel.isChecked()) {\n                int position = inventories.indexOf(selectInventoryViewModel);\n                vgContainer.setItemChecked(position, true);\n                selectedInventory = adapter.getItem(position);\n            }\n        }\n    }", "signature": "void refreshDate(List<SelectInventoryViewModel> inventories)", "full_signature": "@Override public void refreshDate(List<SelectInventoryViewModel> inventories)", "class_method_signature": "SelectPeriodActivity.refreshDate(List<SelectInventoryViewModel> inventories)", "testcase": false, "constructor": false, "invocations": ["refreshDate", "isChecked", "indexOf", "setItemChecked", "getItem"]}, "repository": {"repo_id": 39063523, "url": "https://github.com/SIGLUS/lmis-moz-mobile", "stars": 15, "created": "7/14/2015 8:34:48 AM +00:00", "updates": "2020-01-07T14:05:00+00:00", "fork": "False", "license": "licensed"}}