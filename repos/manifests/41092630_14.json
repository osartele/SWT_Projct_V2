CodeException(HttpStatusCodeException exception, WebRequest request)", "full_signature": "@ExceptionHandler(HttpStatusCodeException.class) protected ResponseEntity<?> handleHttpStatusCodeException(HttpStatusCodeException exception, WebRequest request)", "class_method_signature": "RequestExceptionHandler.handleHttpStatusCodeException(HttpStatusCodeException exception, WebRequest request)", "testcase": false, "constructor": false}, {"identifier": "handleMethodArgumentNotValid", "parameters": "(\n        MethodArgumentNotValidException exception,\n        HttpHeaders headers,\n        HttpStatus status,\n        WebRequest request)", "modifiers": "@Override protected", "return": "ResponseEntity<Object>", "signature": "ResponseEntity<Object> handleMethodArgumentNotValid(\n        MethodArgumentNotValidException exception,\n        HttpHeaders headers,\n        HttpStatus status,\n        WebRequest request)", "full_signature": "@Override protected ResponseEntity<Object> handleMethodArgumentNotValid(\n        MethodArgumentNotValidException exception,\n        HttpHeaders headers,\n        HttpStatus status,\n        WebRequest request)", "class_method_signature": "RequestExceptionHandler.handleMethodArgumentNotValid(\n        MethodArgumentNotValidException exception,\n        HttpHeaders headers,\n        HttpStatus status,\n        WebRequest request)", "testcase": false, "constructor": false}, {"identifier": "processConstraintViolation", "parameters": "(Set<String> fieldNames)", "modifiers": "private", "return": "Map<String, Object>", "signature": "Map<String, Object> processConstraintViolation(Set<String> fieldNames)", "full_signature": "private Map<String, Object> processConstraintViolation(Set<String> fieldNames)", "class_method_signature": "RequestExceptionHandler.processConstraintViolation(Set<String> fieldNames)", "testcase": false, "constructor": false}, {"identifier": "getErrorResponseBody", "parameters": "(int code, String message)", "modifiers": "private", "return": "Map<String, Object>", "signature": "Map<String, Object> getErrorResponseBody(int code, String message)", "full_signature": "private Map<String, Object> getErrorResponseBody(int code, String message)", "class_method_signature": "RequestExceptionHandler.getErrorResponseBody(int code, String message)", "testcase": false, "constructor": false}, {"identifier": "logException", "parameters": "(Exception exception, WebRequest request)", "modifiers": "private", "return": "void", "signature": "void logException(Exception exception, WebRequest request)", "full_signature": "private void logException(Exception exception, WebRequest request)", "class_method_signature": "RequestExceptionHandler.logException(Exception exception, WebRequest request)", "testcase": false, "constructor": false}], "file": "smartcosmos-framework/src/main/java/net/smartcosmos/exceptions/handlers/RequestExceptionHandler.java"}, "focal_method": {"identifier": "handleSmartCosmosExceptionMethod", "parameters": "(SmartCosmosException exception, WebRequest request)", "modifiers": "@ExceptionHandler(SmartCosmosException.class) protected", "return": "ResponseEntity<?>", "body": "@ExceptionHandler(SmartCosmosException.class)\n    protected ResponseEntity<?> handleSmartCosmosExceptionMethod(SmartCosmosException exception, WebRequest request) {\n\n        if (exception.getCause() == null) {\n            logException(exception, request);\n            HttpHeaders headers = new HttpHeaders();\n            HttpStatus status = HttpStatus.INTERNAL_SERVER_ERROR;\n            return handleExceptionInternal(exception, getErrorResponseBody(ERR_FAILURE, exception.getMessage()), headers, status, request);\n\n        }\n        if (exception.getCause() instanceof NoEntityFoundException) {\n            return handleNoEntityFoundRequestHandlingMethod((NoEntityFoundException) exception.getCause(), request);\n        }\n        if (exception.getCause() instanceof ConversionFailedException) {\n            return handleConversionFailure((ConversionFailedException) exception.getCause(), request);\n        }\n        if (exception.getCause() instanceof IllegalArgumentException) {\n            return handleIllegalArgument((IllegalArgumentException) exception.getCause(), request);\n        }\n        if (exception.getCause() instanceof ConstraintViolationException) {\n            return handleConstraintViolation((ConstraintViolationException) exception.getCause(), request);\n        }\n        if (exception.getCause() instanceof HttpStatusCodeException) {\n            return handleHttpStatusCodeException((HttpStatusCodeException) exception.getCause(), request);\n        }\n        if (exception.getCause() instanceof MethodArgumentNotValidException) {\n            HttpHeaders headers = new HttpHeaders();\n            HttpStatus status = HttpStatus.BAD_REQUEST;\n            return handleMethodArgumentNotValid((MethodArgumentNotValidException) exception.getCause(), headers, status, request);\n        }\n        HttpHeaders headers = new HttpHeaders();\n        HttpStatus status = HttpStatus.INTERNAL_SERVER_ERROR;\n\n        return handleExceptionInternal(exception, getErrorResponseBody(ERR_FAILURE, exception.toString()), headers, status, request);\n\n    }", "signature": "ResponseEntity<?> handleSmartCosmosExceptionMethod(SmartCosmosException exception, WebRequest request)", "full_signature": "@ExceptionHandler(SmartCosmosException.class) protected ResponseEntity<?> handleSmartCosmosExceptionMethod(SmartCosmosException exception, WebRequest request)", "class_method_signature": "RequestExceptionHandler.handleSmartCosmosExceptionMethod(SmartCosmosException exception, WebRequest request)", "testcase": false, "constructor": false, "invocations": ["getCause", "logException", "handleExceptionInternal", "getErrorResponseBody", "getMessage", "getCause", "handleNoEntityFoundRequestHandlingMethod", "getCause", "getCause", "handleConversionFailure", "getCause", "getCause", "handleIllegalArgument", "getCause", "getCause", "handleConstraintViolation", "getCause", "getCause", "handleHttpStatusCodeException", "getCause", "getCause", "handleMethodArgumentNotValid", "getCause", "handleExceptionInternal", "getErrorResponseBody", "toString"]}, "repository": {"repo_id": 41092630, "url": "https://github.com/SMARTRACTECHNOLOGY/smartcosmos-framework", "language": "Java", "is_fork": false, "fork_count": 1, "stargazer_count": 5, "size": 23067, "license": "licensed"}}