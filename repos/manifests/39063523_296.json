ousStockOnHand);\n        return lotMovementItem;\n    }", "signature": "LotMovementItem convertViewToModelAndResetSOH(Product product)", "full_signature": "public LotMovementItem convertViewToModelAndResetSOH(Product product)", "class_method_signature": "LotMovementViewModel.convertViewToModelAndResetSOH(Product product)", "testcase": false, "constructor": false, "invocations": ["parseLong", "getLotSoh", "parseLong", "getQuantity", "setProduct", "setLotNumber", "setExpirationDate", "getActualMaximumDate", "parseString", "setLot", "setStockOnHand", "setMovementQuantity"]}, "repository": {"repo_id": 39063523, "url": "https://github.com/SIGLUS/lmis-moz-mobile", "stars": 15, "created": "7/14/2015 8:34:48 AM +00:00", "updates": "2020-01-07T14:05:00+00:00", "fork": "False", "license": "licensed"}}