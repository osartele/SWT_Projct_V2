ram> signReport(String signature, boolean isComplete)", "class_method_signature": "PtvProgramPresenter.signReport(String signature, boolean isComplete)", "testcase": false, "constructor": false}], "file": "app/src/main/java/org/openlmis/core/presenter/PtvProgramPresenter.java"}, "focal_method": {"identifier": "buildInitialPtvProgram", "parameters": "()", "modifiers": "public", "return": "Observable<PTVProgram>", "body": "public Observable<PTVProgram> buildInitialPtvProgram() {\n        return Observable.create(new Observable.OnSubscribe<PTVProgram>() {\n            @Override\n            public void call(Subscriber<? super PTVProgram> subscriber) {\n                try {\n                    if (period == null) {\n                        LMISException e =  new LMISException(\"Period cannot be null\");\n                        e.reportToFabric();\n                        throw e;\n                    }\n                    createPTVProgram();\n                    buildPlaceholderRows();\n                    subscriber.onNext(ptvProgram);\n                    subscriber.onCompleted();\n                } catch (LMISException e) {\n                    subscriber.onError(e);\n                }\n            }\n        }).observeOn(AndroidSchedulers.mainThread()).subscribeOn(Schedulers.io());\n    }", "signature": "Observable<PTVProgram> buildInitialPtvProgram()", "full_signature": "public Observable<PTVProgram> buildInitialPtvProgram()", "class_method_signature": "PtvProgramPresenter.buildInitialPtvProgram()", "testcase": false, "constructor": false, "invocations": ["subscribeOn", "observeOn", "create", "reportToFabric", "createPTVProgram", "buildPlaceholderRows", "onNext", "onCompleted", "onError", "mainThread", "io"]}, "repository": {"repo_id": 39063523, "url": "https://github.com/SIGLUS/lmis-moz-mobile", "stars": 15, "created": "7/14/2015 8:34:48 AM +00:00", "updates": "2020-01-07T14:05:00+00:00", "fork": "False", "license": "licensed"}}