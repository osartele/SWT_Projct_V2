nt[]", "declarator": "response = {0, 1, 2, 3}", "var_name": "response"}], "file": "psychometrics-irt/src/test/java/com/itemanalysis/psychometrics/irt/model/IrmGPCMTest.java"}, "test_case": {"identifier": "gradientTest1", "parameters": "()", "modifiers": "@Test public", "return": "void", "body": "@Test\n    public void gradientTest1(){\n        System.out.println(\"Gradient test 1: Three categories\");\n        double[] step = {0, -0.5, 0.5};\n        IrmGPCM irm = new IrmGPCM(1.2, step, 1.0);\n\n        double[] grad = null;\n\n        //Gradient for first response category\n        grad = irm.gradient(1.0, 0);\n//        System.out.println(Arrays.toString(grad));\n        assertEquals(\"First category, Derivative wrt a\", -9.527941e-02, grad[0], 1e-7);\n        assertEquals(\"First category, Derivative wrt b1\", 8.595784e-13, grad[1], 1e-7);\n        assertEquals(\"First category, Derivative wrt b2\", 6.272412e-02, grad[2], 1e-7);\n        assertEquals(\"First category, Derivative wrt b3\", 4.049822e-02, grad[3], 1e-7);\n\n        //Gradient for second response category\n        grad = irm.gradient(1.0, 1);\n//        System.out.println(Arrays.toString(grad));\n        assertEquals(\"Second category, Derivative wrt  a\", -7.430095e-02, grad[0], 1e-7);\n        assertEquals(\"Second category, Derivative wrt b1\", -3.318921e-14, grad[1], 1e-7);\n        assertEquals(\"Second category, Derivative wrt b2\", -2.222590e-02, grad[2], 1e-7);\n        assertEquals(\"Second category, Derivative wrt b3\", 2.450000e-01, grad[3], 1e-7);\n\n        //Gradient for third response category\n        grad = irm.gradient(1.0, 2);\n//        System.out.println(Arrays.toString(grad));\n        assertEquals(\"Third category, Derivative wrt a\", 1.695804e-01 , grad[0], 1e-7);\n        assertEquals(\"Third category, Derivative wrt b1\", 3.328711e-14, grad[1], 1e-7);\n        assertEquals(\"Third category, Derivative wrt b2\", -4.049822e-02, grad[2], 1e-7);\n        assertEquals(\"Third category, Derivative wrt b3\", -2.854982e-01, grad[3], 1e-7);\n\n    }", "signature": "void gradientTest1()", "full_signature": "@Test public void gradientTest1()", "class_method_signature": "IrmGPCMTest.gradientTest1()", "testcase": true, "constructor": false, "invocations": ["println", "gradient", "assertEquals", "assertEquals", "assertEquals", "assertEquals", "gradient", "assertEquals", "assertEquals", "assertEquals", "assertEquals", "gradient", "assertEquals", "assertEquals", "assertEquals", "assertEquals"]}, "focal_class": {"identifier": "IrmGPCM", "superclass": "extends AbstractItemResponseModel", "interfaces": "", "fields": [{"original_string": "private double discrimination = 1.0;", "modifier": "private", "type": "double", "declarator": "discrimination = 1.0", "var_name": "discrimination"}, {"original_string": "private double discriminationStandardError = 0.0;", "modifier": "private", "type": "double", "declarator": "discriminationStandardError = 0.0", "var_name": "discriminationStandardError"}, {"original_string": "private double proposalDiscrimination = 1.0;", "modifier": "private", "type": "double", "declarator": "proposalDiscrimination = 1.0", "var_name": "proposalDiscrimination"}, {"original_string": "protected double D = 1.7;", "modifier": "protected", "type": "double", "declarator": "D = 1.7", "var_name": "D"}, {"original_string": "protected double[] step;", "modifier": "protected", "type": "double[]", "declarator": "step", "var_name": "step"}, {"original_string": "protected double[] proposalStep;", "modifier": "protected", "type": "double[]", "declarator": "proposalStep", "var_name": "proposalStep"}, {"original_string": "protected double[] stepStdError;", "modifier": "protected", "type": "double[]", "declarator": "stepStdError", "var_name": "stepStdError"}, {"original_string": "private ItemParamPrior discriminationPrior = null;", "modifier": "private", "type": "ItemParamPrior", "declarator": "discriminationPrior = null", "var_name": "discriminationPrior