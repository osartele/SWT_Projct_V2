riber);\n        listImplementationViewModelSubscriber.awaitTerminalEvent();\n\n        listImplementationViewModelSubscriber.assertError(LMISException.class);\n    }", "signature": "void shouldThrowAnExceptionWhenFindForPeriodFails()", "full_signature": "@Test public void shouldThrowAnExceptionWhenFindForPeriodFails()", "class_method_signature": "MalariaDataReportFormPresenterTest.shouldThrowAnExceptionWhenFindForPeriodFails()", "testcase": true, "constructor": false, "invocations": ["findForPeriod", "when", "doThrow", "getBegin", "getEnd", "getImplementationViewModelsForCurrentMalariaProgram", "subscribe", "awaitTerminalEvent", "assertError"]}, "focal_class": {"identifier": "MalariaDataReportFormPresenter", "superclass": "extends BaseReportPresenter", "interfaces": "", "fields": [{"original_string": "public static final int INVALID_INDEX = -1;", "modifier": "public static final", "type": "int", "declarator": "INVALID_INDEX = -1", "var_name": "INVALID_INDEX"}, {"original_string": "@Inject\n    MalariaProgramToMalariaDataReportViewModelMapper reportViewModelMapper;", "modifier": "@Inject", "type": "MalariaProgramToMalariaDataReportViewModelMapper", "declarator": "reportViewModelMapper", "var_name": "reportViewModelMapper"}, {"original_string": "@Inject\n    MalariaDataReportViewModelToMalariaProgramMapper malariaProgramMapper;", "modifier": "@Inject", "type": "MalariaDataReportViewModelToMalariaProgramMapper", "declarator": "malariaProgramMapper", "var_name": "malariaProgramMapper"}, {"original_string": "@Inject\n    PatientDataService patientDataService;", "modifier": "@Inject", "type": "PatientDataService", "declarator": "patientDataService", "var_name": "patientDataService"}, {"original_string": "private Period period;", "modifier": "private", "type": "Period", "declarator": "period", "var_name": "period"}, {"original_string": "private MalariaProgram malariaProgram;", "modifier": "private", "type": "MalariaProgram", "declarator": "malariaProgram", "var_name": "ma