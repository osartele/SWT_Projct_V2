odel(ImplementationReportViewModel usImplementation,\n                                                                 ImplementationReportViewModel apeImplementation)", "class_method_signature": "MalariaDataReportFormPresenter.generateTotalViewModel(ImplementationReportViewModel usImplementation,\n                                                                 ImplementationReportViewModel apeImplementation)", "testcase": false, "constructor": false}, {"identifier": "onSaveForm", "parameters": "(final ViaReportStatus status, final String sign)", "modifiers": "public", "return": "Observable<MalariaProgram>", "signature": "Observable<MalariaProgram> onSaveForm(final ViaReportStatus status, final String sign)", "full_signature": "public Observable<MalariaProgram> onSaveForm(final ViaReportStatus status, final String sign)", "class_method_signature": "MalariaDataReportFormPresenter.onSaveForm(final ViaReportStatus status, final String sign)", "testcase": false, "constructor": false}, {"identifier": "deleteDraft", "parameters": "()", "modifiers": "@Override public", "return": "void", "signature": "void deleteDraft()", "full_signature": "@Override public void deleteDraft()", "class_method_signature": "MalariaDataReportFormPresenter.deleteDraft()", "testcase": false, "constructor": false}, {"identifier": "isDraft", "parameters": "()", "modifiers": "@Override public", "return": "boolean", "signature": "boolean isDraft()", "full_signature": "@Override public boolean isDraft()", "class_method_signature": "MalariaDataReportFormPresenter.isDraft()", "testcase": false, "constructor": false}, {"identifier": "addSignature", "parameters": "(String signature)", "modifiers": "@Override protected", "return": "void", "signature": "void addSignature(String signature)", "full_signature": "@Override protected void addSignature(String signature)", "class_method_signature": "MalariaDataReportFormPresenter.addSignature(String signature)", "testcase": false, "constructor": false}, {"identifier": "isSubmittedForApproval", "parameters": "()", "modifiers": "public", "return": "boolean", "signature": "boolean isSubmittedForApproval()", "full_signature": "public boolean isSubmittedForApproval()", "class_method_signature": "MalariaDataReportFormPresenter.isSubmittedForApproval()", "testcase": false, "constructor": false}], "file": "app/src/main/java/org/openlmis/core/presenter/MalariaDataReportFormPresenter.java"}, "focal_method": {"identifier": "getImplementationViewModelsForCurrentMalariaProgram", "parameters": "(final Period period)", "modifiers": "public", "return": "Observable<List<ImplementationReportViewModel>>", "body": "public Observable<List<ImplementationReportViewModel>> getImplementationViewModelsForCurrentMalariaProgram(final Period period) {\n        this.period = period;\n        return Observable.create((Observable.OnSubscribe<List<ImplementationReportViewModel>>) subscriber -> {\n            try {\n                malariaProgram = patientDataService.findForPeriod(period.getBegin(), period.getEnd());\n                MalariaDataReportViewModel malariaDataReportViewModel = reportViewModelMapper.Map(malariaProgram);\n                ImplementationReportViewModel usImplementationReportViewModel = malariaDataReportViewModel.getUsImplementationReportViewModel();\n                if (malariaProgram != null) {\n                    createdBy = malariaProgram.getCreatedBy();\n                    status = malariaProgram.getStatus();\n                } else {\n                    createdBy = \"\";\n                    status = ViaReportStatus.MISSING;\n                    List<Long> malariaProductsStockHand = patientDataService.getMalariaProductsStockHand();\n                    usImplementationReportViewModel.setExistingStock(malariaProductsStockHand);\n                }\n                viewModels.add(usImplementationReportViewModel);\n                viewModels.add(malariaDataReportViewModel.getApeImplementationReportViewModel());\n                viewModels.add(generateTotalViewModel(viewModels.get(0), viewModels.get(1)));\n                subscriber.onNext(viewModels);\n                subscriber.onCompleted();\n            } catch (Exception e) {\n                new LMISException(e, \"MalariaData:getImple\").reportToFabric();\n                subscriber.onError(e);\n            }\n        }).observeOn(AndroidSchedulers.mainThread()).subscribeOn(Schedulers.io());\n    }", "signature": "Observable<List<ImplementationReportViewModel>> getImplementationViewModelsForCurrentMalariaProgram(final Period period)", "full_signature": "public Observable<List<ImplementationReportViewModel>> getImplementationViewModelsForCurrentMalariaProgram(final Period period)", "class_method_signature": "MalariaDataReportFormPresenter.getImplementationViewModelsForCurrentMalariaProgram(final Period period)", "testcase": false, "constructor": false, "invocations": ["subscribeOn", "observeOn", "create", "findForPeriod", "getBegin", "getEnd", "Map", "getUsImplementationReportViewModel", "getCreatedBy", "getStatus", "getMalariaProductsStockHand", "setExistingStock", "add", "add", "getApeImplementationReportViewModel", "add", "generateTotalViewModel", "get", "get", "onNext", "onCompleted", "reportToFabric", "onError", "mainThread", "io"]}, "repository": {"repo_id": 39063523, "url": "https://github.com/SIGLUS/lmis-moz-mobile", "stars": 15, "created": "7/14/2015 8:34:48 AM +00:00", "updates": "2020-01-07T14:05:00+00:00", "fork": "False", "license": "licensed"}}