ctById(final long id)", "class_method_signature": "ProductRepository.getProductById(final long id)", "testcase": false, "constructor": false}, {"identifier": "queryActiveProductsByCodesWithKits", "parameters": "(final List<String> productCodes, final boolean isWithKit)", "modifiers": "public", "return": "List<Product>", "signature": "List<Product> queryActiveProductsByCodesWithKits(final List<String> productCodes, final boolean isWithKit)", "full_signature": "public List<Product> queryActiveProductsByCodesWithKits(final List<String> productCodes, final boolean isWithKit)", "class_method_signature": "ProductRepository.queryActiveProductsByCodesWithKits(final List<String> productCodes, final boolean isWithKit)", "testcase": false, "constructor": false}, {"identifier": "queryKitProductByProductCode", "parameters": "(final String productCode)", "modifiers": "public", "return": "List<KitProduct>", "signature": "List<KitProduct> queryKitProductByProductCode(final String productCode)", "full_signature": "public List<KitProduct> queryKitProductByProductCode(final String productCode)", "class_method_signature": "ProductRepository.queryKitProductByProductCode(final String productCode)", "testcase": false, "constructor": false}, {"identifier": "listArchivedProductCodes", "parameters": "()", "modifiers": "public", "return": "List<String>", "signature": "List<String> listArchivedProductCodes()", "full_signature": "public List<String> listArchivedProductCodes()", "class_method_signature": "ProductRepository.listArchivedProductCodes()", "testcase": false, "constructor": false}, {"identifier": "queryProductsByProductIds", "parameters": "(final List<Long> productIds)", "modifiers": "public", "return": "List<Product>", "signature": "List<Product> queryProductsByProductIds(final List<Long> productIds)", "full_signature": "public List<Product> queryProductsByProductIds(final List<Long> productIds)", "class_method_signature": "ProductRepository.queryProductsByProductIds(final List<Long> productIds)", "testcase": false, "constructor": false}, {"identifier": "queryActiveProductsInVIAProgramButNotInDraftVIAForm", "parameters": "()", "modifiers": "public", "return": "List<Product>", "signature": "List<Product> queryActiveProductsInVIAProgramButNotInDraftVIAForm()", "full_signature": "public List<Product> queryActiveProductsInVIAProgramButNotInDraftVIAForm()", "class_method_signature": "ProductRepository.queryActiveProductsInVIAProgramButNotInDraftVIAForm()", "testcase": false, "constructor": false}, {"identifier": "listNonBasicProducts", "parameters": "()", "modifiers": "public", "return": "List<Product>", "signature": "List<Product> listNonBasicProducts()", "full_signature": "public List<Product> listNonBasicProducts()", "class_method_signature": "ProductRepository.listNonBasicProducts()", "testcase": false, "constructor": false}, {"identifier": "getProductsByCodes", "parameters": "(final List<String> codes)", "modifiers": "public", "return": "List<Product>", "signature": "List<Product> getProductsByCodes(final List<String> codes)", "full_signature": "public List<Product> getProductsByCodes(final List<String> codes)", "class_method_signature": "ProductRepository.getProductsByCodes(final List<String> codes)", "testcase": false, "constructor": false}], "file": "app/src/main/java/org/openlmis/core/model/repository/ProductRepository.java"}, "focal_method": {"identifier": "listNonBasicProducts", "parameters": "()", "modifiers": "public", "return": "List<Product>", "body": "public List<Product> listNonBasicProducts() {\n        String rawSql = \"SELECT * FROM products \"\n                + \"WHERE isactive = '1' \"\n                + \"AND products.isbasic = '0' \"\n                + \"AND (isarchived = '1' \"\n                + \"OR id NOT IN (\"\n                + \"SELECT product_id from stock_cards));\";\n\n        final Cursor cursor = LmisSqliteOpenHelper.getInstance(LMISApp.getContext()).getWritableDatabase().rawQuery(rawSql, null);\n        List<Product> nonBasicProducts = new ArrayList<>();\n\n        if (cursor.moveToFirst()) {\n            do {\n                Product product = new Product();\n\n                product.setActive(Boolean.TRUE);\n                product.setPrimaryName(cursor.getString(cursor.getColumnIndexOrThrow(\"primaryName\")));\n                product.setArchived(cursor.getInt(cursor.getColumnIndexOrThrow(\"isArchived\")) != 0);\n                product.setCode(cursor.getString(cursor.getColumnIndexOrThrow(\"code\")));\n                product.setId(cursor.getInt(cursor.getColumnIndexOrThrow(\"id\")));\n                product.setStrength(cursor.getString(cursor.getColumnIndexOrThrow(\"strength\")));\n                product.setType(cursor.getString(cursor.getColumnIndexOrThrow(\"type\")));\n                nonBasicProducts.add(product);\n            } while (cursor.moveToNext());\n        }\n        if (cursor != null && !cursor.isClosed()) {\n            cursor.close();\n        }\n        Collections.sort(nonBasicProducts);\n        return nonBasicProducts;\n    }", "signature": "List<Product> listNonBasicProducts()", "full_signature": "public List<Product> listNonBasicProducts()", "class_method_signature": "ProductRepository.listNonBasicProducts()", "testcase": false, "constructor": false, "invocations": ["rawQuery", "getWritableDatabase", "getInstance", "getContext", "moveToFirst", "setActive", "setPrimaryName", "getString", "getColumnIndexOrThrow", "setArchived", "getInt", "getColumnIndexOrThrow", "setCode", "getString", "getColumnIndexOrThrow", "setId", "getInt", "getColumnIndexOrThrow", "setStrength", "getString", "getColumnIndexOrThrow", "setType", "getString", "getColumnIndexOrThrow", "add", "moveToNext", "isClosed", "close", "sort"]}, "repository": {"repo_id": 39063523, "url": "https://github.com/SIGLUS/lmis-moz-mobile", "stars": 15, "created": "7/14/2015 8:34:48 AM +00:00", "updates": "2020-01-07T14:05:00+00:00", "fork": "False", "license": "licensed"}}