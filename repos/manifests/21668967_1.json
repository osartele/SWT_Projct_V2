Name.asc(), u3, u4);\n        assertQuery(user.firstName.eq(\"Jaana\"), user.lastName.desc(), u4, u3);\n        assertQuery(user.lastName.eq(\"Jantunen\"), user.firstName.asc(), u2, u1);\n        assertQuery(user.lastName.eq(\"Jantunen\"), user.firstName.desc(), u1, u2);\n\n        assertQuery(user.firstName.eq(\"Jaana\").and(user.lastName.eq(\"Aakkonen\")), u3);\n        //This shoud produce 'and' also\n        assertQuery(where(user.firstName.eq(\"Jaana\"), user.lastName.eq(\"Aakkonen\")), u3);\n\n        assertQuery(user.firstName.ne(\"Jaana\"), u2, u1);\n        assertQuery(user.firstName.ne(\"Jaana\").and(user.lastName.ne(\"Jantunen\")));\n        assertQuery(user.firstName.eq(\"Jaana\").and(user.lastName.eq(\"Aakkonen\")).not(), u4, u2, u1);\n\n    }", "signature": "void EqInAndOrderByQueries()", "full_signature": "@Test public void EqInAndOrderByQueries()", "class_method_signature": "ElasticsearchQueryTest.EqInAndOrderByQueries()", "testcase": true, "constructor": false, "invocations": ["assertQuery", "eq", "assertQuery", "equalsIgnoreCase", "assertQuery", "eq", "assertQuery", "in", "assertQuery", "in", "assertQuery", "eq", "assertQuery", "eq", "asc", "assertQuery", "eq", "desc", "assertQuery", "eq", "asc", "assertQuery", "eq", "desc", "assertQuery", "and", "eq", "eq", "assertQuery", "where", "eq", "eq", "assertQuery", "ne", "assertQuery", "and", "ne", "ne", "assertQuery", "not", "and", "eq", "eq"]}, "focal_class": {"identifier": "ElasticsearchQuery", "superclass": "", "interfaces": "implements SimpleQuery<ElasticsearchQuery<K>>, Fetchable<K>", "fields": [{"original_string": "private final QueryMixin<ElasticsearchQuery<K>> queryMixin;", "modifier": "private final", "type": "QueryMixin<ElasticsearchQuery<K>>", "declarator": "queryMixin", "var_name": "queryMixin"}, {"original_string": "private final Client client;", "modifier": "private final", "type": "Client", "declarator": "client", "var_name": "client"}, {"original_string": "private final Function<SearchHit