gnature": "SyncUpManager.markProgramDataFormsSynced(ProgramDataForm programDataForm)", "testcase": false, "constructor": false}], "file": "app/src/main/java/org/openlmis/core/service/SyncUpManager.java"}, "focal_method": {"identifier": "syncUpCmms", "parameters": "()", "modifiers": "public", "return": "void", "body": "public void syncUpCmms() {\n        try {\n            List<Cmm> unsyncedCmms = cmmRepository.listUnsynced();\n            if (!unsyncedCmms.isEmpty()) {\n                List<CmmEntry> cmmEntries = FluentIterable\n                        .from(unsyncedCmms)\n                        .transform(CmmEntry::createFrom)\n                        .toList();\n\n                lmisRestApi.syncUpCmms(UserInfoMgr.getInstance().getUser().getFacilityId(), cmmEntries);\n\n                for (Cmm cmm : unsyncedCmms) {\n                    cmm.setSynced(true);\n                    cmmRepository.save(cmm);\n                }\n            }\n        } catch (LMISException e) {\n            new LMISException(e, \"SyncUpManager.syncUpCmms\").reportToFabric();\n        }\n    }", "signature": "void syncUpCmms()", "full_signature": "public void syncUpCmms()", "class_method_signature": "SyncUpManager.syncUpCmms()", "testcase": false, "constructor": false, "invocations": ["listUnsynced", "isEmpty", "toList", "transform", "from", "syncUpCmms", "getFacilityId", "getUser", "getInstance", "setSynced", "save", "reportToFabric"]}, "repository": {"repo_id": 39063523, "url": "https://github.com/SIGLUS/lmis-moz-mobile", "stars": 15, "created": "7/14/2015 8:34:48 AM +00:00", "updates": "2020-01-07T14:05:00+00:00", "fork": "False", "license": "licensed"}}