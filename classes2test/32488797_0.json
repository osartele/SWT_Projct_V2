Java", "parameters": "()", "modifiers": "", "return": "String", "signature": "String brewJava()", "full_signature": " String brewJava()", "class_method_signature": "ResourceInjector.brewJava()", "testcase": false, "constructor": false}, {"identifier": "emitInject", "parameters": "(StringBuilder builder)", "modifiers": "", "return": "void", "signature": "void emitInject(StringBuilder builder)", "full_signature": " void emitInject(StringBuilder builder)", "class_method_signature": "ResourceInjector.emitInject(StringBuilder builder)", "testcase": false, "constructor": false}, {"identifier": "emitResourceInjection", "parameters": "(StringBuilder builder, ResourceInjection injection)", "modifiers": "", "return": "void", "signature": "void emitResourceInjection(StringBuilder builder, ResourceInjection injection)", "full_signature": " void emitResourceInjection(StringBuilder builder, ResourceInjection injection)", "class_method_signature": "ResourceInjector.emitResourceInjection(StringBuilder builder, ResourceInjection injection)", "testcase": false, "constructor": false}, {"identifier": "emitFieldBindings", "parameters": "(StringBuilder builder, ResourceInjection injection)", "modifiers": "", "return": "void", "signature": "void emitFieldBindings(StringBuilder builder, ResourceInjection injection)", "full_signature": " void emitFieldBindings(StringBuilder builder, ResourceInjection injection)", "class_method_signature": "ResourceInjector.emitFieldBindings(StringBuilder builder, ResourceInjection injection)", "testcase": false, "constructor": false}], "file": "vitaminsaber/src/main/java/com/w2ji/vitaminsaber/internal/ResourceInjector.java"}, "focal_method": {"identifier": "emitHumanDescription", "parameters": "(StringBuilder builder, List<FieldBinding> bindings)", "modifiers": "static", "return": "void", "body": "static void emitHumanDescription(StringBuilder builder, List<FieldBinding> bindings) {\n        switch (bindings.size()) {\n            case 1:\n                builder.append(bindings.get(0).getDescription());\n                break;\n            case 2:\n                builder.append(bindings.get(0).getDescription())\n                        .append(\" and \")\n                        .append(bindings.get(1).getDescription());\n                break;\n            default:\n                for (int i = 0, count = bindings.size(); i < count; i++) {\n                    FieldBinding requiredField = bindings.get(i);\n                    if (i != 0) {\n                        builder.append(\", \");\n                    }\n                    if (i == count - 1) {\n                        builder.append(\"and \");\n                    }\n                    builder.append(requiredField.getDescription());\n                }\n                break;\n        }\n    }", "signature": "void emitHumanDescription(StringBuilder builder, List<FieldBinding> bindings)", "full_signature": "static void emitHumanDescription(StringBuilder builder, List<FieldBinding> bindings)", "class_method_signature": "ResourceInjector.emitHumanDescription(StringBuilder builder, List<FieldBinding> bindings)", "testcase": false, "constructor": false, "invocations": ["size", "append", "getDescription", "get", "append", "append", "append", "getDescription", "get", "getDescription", "get", "size", "get", "append", "append", "append", "getDescription"]}, "repository": {"repo_id": 32488797, "url": "https://github.com/w2ji/VitaminSaber", "language": "Java", "is_fork": false, "fork_count": 7, "stargazer_count": 99, "size": 296, "license": "licensed"}}